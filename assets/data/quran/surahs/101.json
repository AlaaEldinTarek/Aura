{
  "number": 101,
  "name": "سُورَةُ القَارِعَةِ",
  "englishName": "Al-Qaari'a",
  "englishNameTranslation": "The Calamity",
  "revelationType": "Meccan",
  "numberOfAyahs": 11,
  "ayahs": [
    {
      "number": 6158,
      "numberInSurah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ ٱلْقَارِعَةُ",
      "translation": "OH, the sudden calamity!",
      "juz": 30,
      "page": 600,
      "ruku": 543,
      "sajda": false
    },
    {
      "number": 6159,
      "numberInSurah": 2,
      "text": "مَا ٱلْقَارِعَةُ",
      "translation": "How awesome the sudden calamity!",
      "juz": 30,
      "page": 600,
      "ruku": 543,
      "sajda": false
    },
    {
      "number": 6160,
      "numberInSurah": 3,
      "text": "وَمَآ أَدْرَىٰكَ مَا ٱلْقَارِعَةُ",
      "translation": "And what could make thee conceive what that sudden calamity will be?",
      "juz": 30,
      "page": 600,
      "ruku": 543,
      "sajda": false
    },
    {
      "number": 6161,
      "numberInSurah": 4,
      "text": "يَوْمَ يَكُونُ ٱلنَّاسُ كَٱلْفَرَاشِ ٱلْمَبْثُوثِ",
      "translation": "[It will occur] on the Day when men will be like moths swarming in confusion,",
      "juz": 30,
      "page": 600,
      "ruku": 543,
      "sajda": false
    },
    {
      "number": 6162,
      "numberInSurah": 5,
      "text": "وَتَكُونُ ٱلْجِبَالُ كَٱلْعِهْنِ ٱلْمَنفُوشِ",
      "translation": "and the mountains will be like fluffy tufts of wool....",
      "juz": 30,
      "page": 600,
      "ruku": 543,
      "sajda": false
    },
    {
      "number": 6163,
      "numberInSurah": 6,
      "text": "فَأَمَّا مَن ثَقُلَتْ مَوَٰزِينُهُۥ",
      "translation": "And then, he whose weight [of good deeds] is heavy in the balance",
      "juz": 30,
      "page": 600,
      "ruku": 543,
      "sajda": false
    },
    {
      "number": 6164,
      "numberInSurah": 7,
      "text": "فَهُوَ فِى عِيشَةٍۢ رَّاضِيَةٍۢ",
      "translation": "shall find himself in a happy' state of life;",
      "juz": 30,
      "page": 600,
      "ruku": 543,
      "sajda": false
    },
    {
      "number": 6165,
      "numberInSurah": 8,
      "text": "وَأَمَّا مَنْ خَفَّتْ مَوَٰزِينُهُۥ",
      "translation": "whereas he whose weight is light in the balance",
      "juz": 30,
      "page": 600,
      "ruku": 543,
      "sajda": false
    },
    {
      "number": 6166,
      "numberInSurah": 9,
      "text": "فَأُمُّهُۥ هَاوِيَةٌۭ",
      "translation": "shall be engulfed by an abyss.",
      "juz": 30,
      "page": 600,
      "ruku": 543,
      "sajda": false
    },
    {
      "number": 6167,
      "numberInSurah": 10,
      "text": "وَمَآ أَدْرَىٰكَ مَا هِيَهْ",
      "translation": "And what could make thee conceive what that [abyss] will be?",
      "juz": 30,
      "page": 600,
      "ruku": 543,
      "sajda": false
    },
    {
      "number": 6168,
      "numberInSurah": 11,
      "text": "نَارٌ حَامِيَةٌۢ",
      "translation": "A fire hotly burning!",
      "juz": 30,
      "page": 600,
      "ruku": 543,
      "sajda": false
    }
  ]
}