{
  "number": 79,
  "name": "سُورَةُ النَّازِعَاتِ",
  "englishName": "An-Naazi'aat",
  "englishNameTranslation": "Those who drag forth",
  "revelationType": "Meccan",
  "numberOfAyahs": 46,
  "ayahs": [
    {
      "number": 5713,
      "numberInSurah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلنَّٰزِعَٰتِ غَرْقًۭا",
      "translation": "CONSIDER those [stars] that rise only to set,",
      "juz": 30,
      "page": 583,
      "ruku": 520,
      "sajda": false
    },
    {
      "number": 5714,
      "numberInSurah": 2,
      "text": "وَٱلنَّٰشِطَٰتِ نَشْطًۭا",
      "translation": "and move [in their orbits] with steady motion,",
      "juz": 30,
      "page": 583,
      "ruku": 520,
      "sajda": false
    },
    {
      "number": 5715,
      "numberInSurah": 3,
      "text": "وَٱلسَّٰبِحَٰتِ سَبْحًۭا",
      "translation": "and float [through space] with floating serene,",
      "juz": 30,
      "page": 583,
      "ruku": 520,
      "sajda": false
    },
    {
      "number": 5716,
      "numberInSurah": 4,
      "text": "فَٱلسَّٰبِقَٰتِ سَبْقًۭا",
      "translation": "and yet overtake [one another] with swift overtaking:",
      "juz": 30,
      "page": 583,
      "ruku": 520,
      "sajda": false
    },
    {
      "number": 5717,
      "numberInSurah": 5,
      "text": "فَٱلْمُدَبِّرَٰتِ أَمْرًۭا",
      "translation": "and thus they fulfil the [Creator's] behest!",
      "juz": 30,
      "page": 583,
      "ruku": 520,
      "sajda": false
    },
    {
      "number": 5718,
      "numberInSurah": 6,
      "text": "يَوْمَ تَرْجُفُ ٱلرَّاجِفَةُ",
      "translation": "[HENCE, think of] the Day when a violent convulsion will convulse [the world],",
      "juz": 30,
      "page": 583,
      "ruku": 520,
      "sajda": false
    },
    {
      "number": 5719,
      "numberInSurah": 7,
      "text": "تَتْبَعُهَا ٱلرَّادِفَةُ",
      "translation": "to be followed by further [convulsions]!",
      "juz": 30,
      "page": 583,
      "ruku": 520,
      "sajda": false
    },
    {
      "number": 5720,
      "numberInSurah": 8,
      "text": "قُلُوبٌۭ يَوْمَئِذٍۢ وَاجِفَةٌ",
      "translation": "On that Day will [men's] hearts be throbbing,",
      "juz": 30,
      "page": 583,
      "ruku": 520,
      "sajda": false
    },
    {
      "number": 5721,
      "numberInSurah": 9,
      "text": "أَبْصَٰرُهَا خَٰشِعَةٌۭ",
      "translation": "[and] their eyes downcast...",
      "juz": 30,
      "page": 583,
      "ruku": 520,
      "sajda": false
    },
    {
      "number": 5722,
      "numberInSurah": 10,
      "text": "يَقُولُونَ أَءِنَّا لَمَرْدُودُونَ فِى ٱلْحَافِرَةِ",
      "translation": "[And yet,] some say, \"What! Are we indeed to be restored to our former state –",
      "juz": 30,
      "page": 583,
      "ruku": 520,
      "sajda": false
    },
    {
      "number": 5723,
      "numberInSurah": 11,
      "text": "أَءِذَا كُنَّا عِظَٰمًۭا نَّخِرَةًۭ",
      "translation": "even though we may have become [a heap of] crumbling bones?\"",
      "juz": 30,
      "page": 583,
      "ruku": 520,
      "sajda": false
    },
    {
      "number": 5724,
      "numberInSurah": 12,
      "text": "قَالُوا۟ تِلْكَ إِذًۭا كَرَّةٌ خَاسِرَةٌۭ",
      "translation": "[And] they add, \"That, then, would be a return with loss!\"",
      "juz": 30,
      "page": 583,
      "ruku": 520,
      "sajda": false
    },
    {
      "number": 5725,
      "numberInSurah": 13,
      "text": "فَإِنَّمَا هِىَ زَجْرَةٌۭ وَٰحِدَةٌۭ",
      "translation": "[But,] then, that [Last Hour] will be [upon them of a sudden, as if it were] but a single accusing cry -",
      "juz": 30,
      "page": 583,
      "ruku": 520,
      "sajda": false
    },
    {
      "number": 5726,
      "numberInSurah": 14,
      "text": "فَإِذَا هُم بِٱلسَّاهِرَةِ",
      "translation": "and then, lo, they will be fully awakened [to the truth]!",
      "juz": 30,
      "page": 583,
      "ruku": 520,
      "sajda": false
    },
    {
      "number": 5727,
      "numberInSurah": 15,
      "text": "هَلْ أَتَىٰكَ حَدِيثُ مُوسَىٰٓ",
      "translation": "HAS THE STORY of Moses ever come within thy ken.",
      "juz": 30,
      "page": 583,
      "ruku": 520,
      "sajda": false
    },
    {
      "number": 5728,
      "numberInSurah": 16,
      "text": "إِذْ نَادَىٰهُ رَبُّهُۥ بِٱلْوَادِ ٱلْمُقَدَّسِ طُوًى",
      "translation": "Lo! His Sustainer called out to him in the twice-hallowed valley:",
      "juz": 30,
      "page": 584,
      "ruku": 520,
      "sajda": false
    },
    {
      "number": 5729,
      "numberInSurah": 17,
      "text": "ٱذْهَبْ إِلَىٰ فِرْعَوْنَ إِنَّهُۥ طَغَىٰ",
      "translation": "\"Go unto Pharaoh - for, verily, he has transgressed all bounds of what is right -",
      "juz": 30,
      "page": 584,
      "ruku": 520,
      "sajda": false
    },
    {
      "number": 5730,
      "numberInSurah": 18,
      "text": "فَقُلْ هَل لَّكَ إِلَىٰٓ أَن تَزَكَّىٰ",
      "translation": "and say [unto him], 'Art thou desirous of attaining to purity?",
      "juz": 30,
      "page": 584,
      "ruku": 520,
      "sajda": false
    },
    {
      "number": 5731,
      "numberInSurah": 19,
      "text": "وَأَهْدِيَكَ إِلَىٰ رَبِّكَ فَتَخْشَىٰ",
      "translation": "[If so,] then I shall guide thee towards [a cognition of] thy Sustainer, so that [henceforth] thou wilt stand in awe [of Him].’\"",
      "juz": 30,
      "page": 584,
      "ruku": 520,
      "sajda": false
    },
    {
      "number": 5732,
      "numberInSurah": 20,
      "text": "فَأَرَىٰهُ ٱلْءَايَةَ ٱلْكُبْرَىٰ",
      "translation": "And thereupon he [went to Pharaoh and] made him aware of the great wonder [of God's grace].",
      "juz": 30,
      "page": 584,
      "ruku": 520,
      "sajda": false
    },
    {
      "number": 5733,
      "numberInSurah": 21,
      "text": "فَكَذَّبَ وَعَصَىٰ",
      "translation": "But [Pharaoh] gave him the lie and rebelliously rejected [all guidance],",
      "juz": 30,
      "page": 584,
      "ruku": 520,
      "sajda": false
    },
    {
      "number": 5734,
      "numberInSurah": 22,
      "text": "ثُمَّ أَدْبَرَ يَسْعَىٰ",
      "translation": "and brusquely turned his back [on Moses];",
      "juz": 30,
      "page": 584,
      "ruku": 520,
      "sajda": false
    },
    {
      "number": 5735,
      "numberInSurah": 23,
      "text": "فَحَشَرَ فَنَادَىٰ",
      "translation": "and then he gathered [his great ones], and called [unto his people],",
      "juz": 30,
      "page": 584,
      "ruku": 520,
      "sajda": false
    },
    {
      "number": 5736,
      "numberInSurah": 24,
      "text": "فَقَالَ أَنَا۠ رَبُّكُمُ ٱلْأَعْلَىٰ",
      "translation": "and said, \"I am your Lord All-Highest!\"",
      "juz": 30,
      "page": 584,
      "ruku": 520,
      "sajda": false
    },
    {
      "number": 5737,
      "numberInSurah": 25,
      "text": "فَأَخَذَهُ ٱللَّهُ نَكَالَ ٱلْءَاخِرَةِ وَٱلْأُولَىٰٓ",
      "translation": "And thereupon God took him to task, [and made him] a warning example in the life to come as well as in this world.",
      "juz": 30,
      "page": 584,
      "ruku": 520,
      "sajda": false
    },
    {
      "number": 5738,
      "numberInSurah": 26,
      "text": "إِنَّ فِى ذَٰلِكَ لَعِبْرَةًۭ لِّمَن يَخْشَىٰٓ",
      "translation": "In this, behold, there is a lesson indeed for all who stand in awe [of God].",
      "juz": 30,
      "page": 584,
      "ruku": 520,
      "sajda": false
    },
    {
      "number": 5739,
      "numberInSurah": 27,
      "text": "ءَأَنتُمْ أَشَدُّ خَلْقًا أَمِ ٱلسَّمَآءُ ۚ بَنَىٰهَا",
      "translation": "[O MEN!] Are you more difficult to create than the heaven which He has built?",
      "juz": 30,
      "page": 584,
      "ruku": 521,
      "sajda": false
    },
    {
      "number": 5740,
      "numberInSurah": 28,
      "text": "رَفَعَ سَمْكَهَا فَسَوَّىٰهَا",
      "translation": "High has He reared its vault and formed it in accordance with what it was meant to be;",
      "juz": 30,
      "page": 584,
      "ruku": 521,
      "sajda": false
    },
    {
      "number": 5741,
      "numberInSurah": 29,
      "text": "وَأَغْطَشَ لَيْلَهَا وَأَخْرَجَ ضُحَىٰهَا",
      "translation": "and He has made dark its night and brought forth its light of day.",
      "juz": 30,
      "page": 584,
      "ruku": 521,
      "sajda": false
    },
    {
      "number": 5742,
      "numberInSurah": 30,
      "text": "وَٱلْأَرْضَ بَعْدَ ذَٰلِكَ دَحَىٰهَآ",
      "translation": "And after that, the earth: wide has He spread its expanse,",
      "juz": 30,
      "page": 584,
      "ruku": 521,
      "sajda": false
    },
    {
      "number": 5743,
      "numberInSurah": 31,
      "text": "أَخْرَجَ مِنْهَا مَآءَهَا وَمَرْعَىٰهَا",
      "translation": "and has caused its waters to come out of it, and its pastures,",
      "juz": 30,
      "page": 584,
      "ruku": 521,
      "sajda": false
    },
    {
      "number": 5744,
      "numberInSurah": 32,
      "text": "وَٱلْجِبَالَ أَرْسَىٰهَا",
      "translation": "and has made the mountains firm:",
      "juz": 30,
      "page": 584,
      "ruku": 521,
      "sajda": false
    },
    {
      "number": 5745,
      "numberInSurah": 33,
      "text": "مَتَٰعًۭا لَّكُمْ وَلِأَنْعَٰمِكُمْ",
      "translation": "[all this] as a means of livelihood for you and your animals.",
      "juz": 30,
      "page": 584,
      "ruku": 521,
      "sajda": false
    },
    {
      "number": 5746,
      "numberInSurah": 34,
      "text": "فَإِذَا جَآءَتِ ٱلطَّآمَّةُ ٱلْكُبْرَىٰ",
      "translation": "AND SO, when the great overwhelming event [of, resurrection] comes to pass –",
      "juz": 30,
      "page": 584,
      "ruku": 521,
      "sajda": false
    },
    {
      "number": 5747,
      "numberInSurah": 35,
      "text": "يَوْمَ يَتَذَكَّرُ ٱلْإِنسَٰنُ مَا سَعَىٰ",
      "translation": "on that Day man will [clearly] remember all that he has ever wrought;",
      "juz": 30,
      "page": 584,
      "ruku": 521,
      "sajda": false
    },
    {
      "number": 5748,
      "numberInSurah": 36,
      "text": "وَبُرِّزَتِ ٱلْجَحِيمُ لِمَن يَرَىٰ",
      "translation": "and the blazing fire [of hell] will be lad open before all who [are destined to] see it.",
      "juz": 30,
      "page": 584,
      "ruku": 521,
      "sajda": false
    },
    {
      "number": 5749,
      "numberInSurah": 37,
      "text": "فَأَمَّا مَن طَغَىٰ",
      "translation": "For, unto him who shall have transgressed the bounds of what is right,",
      "juz": 30,
      "page": 584,
      "ruku": 521,
      "sajda": false
    },
    {
      "number": 5750,
      "numberInSurah": 38,
      "text": "وَءَاثَرَ ٱلْحَيَوٰةَ ٱلدُّنْيَا",
      "translation": "and preferred the life of this world [to the good of his soul],",
      "juz": 30,
      "page": 584,
      "ruku": 521,
      "sajda": false
    },
    {
      "number": 5751,
      "numberInSurah": 39,
      "text": "فَإِنَّ ٱلْجَحِيمَ هِىَ ٱلْمَأْوَىٰ",
      "translation": "that blazing fire will truly be the goal!",
      "juz": 30,
      "page": 584,
      "ruku": 521,
      "sajda": false
    },
    {
      "number": 5752,
      "numberInSurah": 40,
      "text": "وَأَمَّا مَنْ خَافَ مَقَامَ رَبِّهِۦ وَنَهَى ٱلنَّفْسَ عَنِ ٱلْهَوَىٰ",
      "translation": "But unto him who shall have stood in fear of his Sustainer's Presence, and held back his inner self from base desires,",
      "juz": 30,
      "page": 584,
      "ruku": 521,
      "sajda": false
    },
    {
      "number": 5753,
      "numberInSurah": 41,
      "text": "فَإِنَّ ٱلْجَنَّةَ هِىَ ٱلْمَأْوَىٰ",
      "translation": "paradise will truly be the goal!",
      "juz": 30,
      "page": 584,
      "ruku": 521,
      "sajda": false
    },
    {
      "number": 5754,
      "numberInSurah": 42,
      "text": "يَسْـَٔلُونَكَ عَنِ ٱلسَّاعَةِ أَيَّانَ مُرْسَىٰهَا",
      "translation": "THEY WILL ASK thee [O Prophet] about the Last Hour: \"When will it come to pass?\"",
      "juz": 30,
      "page": 584,
      "ruku": 521,
      "sajda": false
    },
    {
      "number": 5755,
      "numberInSurah": 43,
      "text": "فِيمَ أَنتَ مِن ذِكْرَىٰهَآ",
      "translation": "[But] how couldst thou tell anything about it,",
      "juz": 30,
      "page": 584,
      "ruku": 521,
      "sajda": false
    },
    {
      "number": 5756,
      "numberInSurah": 44,
      "text": "إِلَىٰ رَبِّكَ مُنتَهَىٰهَآ",
      "translation": "[seeing that] with thy Sustainer alone rests the beginning and the end [of all knowledge] thereof?",
      "juz": 30,
      "page": 584,
      "ruku": 521,
      "sajda": false
    },
    {
      "number": 5757,
      "numberInSurah": 45,
      "text": "إِنَّمَآ أَنتَ مُنذِرُ مَن يَخْشَىٰهَا",
      "translation": "Thou art but [sent] to warn those who stand in awe of it.",
      "juz": 30,
      "page": 584,
      "ruku": 521,
      "sajda": false
    },
    {
      "number": 5758,
      "numberInSurah": 46,
      "text": "كَأَنَّهُمْ يَوْمَ يَرَوْنَهَا لَمْ يَلْبَثُوٓا۟ إِلَّا عَشِيَّةً أَوْ ضُحَىٰهَا",
      "translation": "On the Day when they behold it, [it will seem to them] as if they had tarried [in this world] no longer than one evening or [one night, ending with] its morn!",
      "juz": 30,
      "page": 584,
      "ruku": 521,
      "sajda": false
    }
  ]
}