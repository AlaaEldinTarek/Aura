  "englishName": "Ash-Sharh",
  "englishNameTranslation": "The Consolation",
  "revelationType": "Meccan",
  "numberOfAyahs": 8,
  "ayahs": [
    {
      "number": 6091,
      "numberInSurah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ أَلَمْ نَشْرَحْ لَكَ صَدْرَكَ",
      "translation": "HAVE WE NOT opened up thy heart,",
      "juz": 30,
      "page": 596,
      "ruku": 536,
      "sajda": false
    },
    {
      "number": 6092,
      "numberInSurah": 2,
      "text": "وَوَضَعْنَا عَنكَ وِزْرَكَ",
      "translation": "and lifted from thee the burden",
      "juz": 30,
      "page": 596,
      "ruku": 536,
      "sajda": false
    },
    {
      "number": 6093,
      "numberInSurah": 3,
      "text": "ٱلَّذِىٓ أَنقَضَ ظَهْرَكَ",
      "translation": "that had weighed so heavily on thy back?",
      "juz": 30,
      "page": 596,
      "ruku": 536,
      "sajda": false
    },
    {
      "number": 6094,
      "numberInSurah": 4,
      "text": "وَرَفَعْنَا لَكَ ذِكْرَكَ",
      "translation": "And [have We not] raised thee high in dignity?",
      "juz": 30,
      "page": 596,
      "ruku": 536,
      "sajda": false
    },
    {
      "number": 6095,
      "numberInSurah": 5,
      "text": "فَإِنَّ مَعَ ٱلْعُسْرِ يُسْرًا",
      "translation": "And, behold, with every hardship comes ease:",
      "juz": 30,
      "page": 596,
      "ruku": 536,
      "sajda": false
    },
    {
      "number": 6096,
      "numberInSurah": 6,
      "text": "إِنَّ مَعَ ٱلْعُسْرِ يُسْرًۭا",
      "translation": "verily, with every hardship comes ease!",
      "juz": 30,
      "page": 596,
      "ruku": 536,
      "sajda": false
    },
    {
      "number": 6097,
      "numberInSurah": 7,
      "text": "فَإِذَا فَرَغْتَ فَٱنصَبْ",
      "translation": "Hence, when thou art freed [from distress], remain steadfast,",
      "juz": 30,
      "page": 596,
      "ruku": 536,
      "sajda": false
    },
    {
      "number": 6098,
      "numberInSurah": 8,
      "text": "وَإِلَىٰ رَبِّكَ فَٱرْغَب",
      "translation": "and unto thy Sustainer turn with love.",
      "juz": 30,
      "page": 596,
      "ruku": 536,
      "sajda": false
    }
