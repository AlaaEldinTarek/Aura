  "englishName": "Ad-Dhuhaa",
  "englishNameTranslation": "The Morning Hours",
  "revelationType": "Meccan",
  "numberOfAyahs": 11,
  "ayahs": [
    {
      "number": 6080,
      "numberInSurah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلضُّحَىٰ",
      "translation": "CONSIDER the bright morning hours,",
      "juz": 30,
      "page": 596,
      "ruku": 535,
      "sajda": false
    },
    {
      "number": 6081,
      "numberInSurah": 2,
      "text": "وَٱلَّيْلِ إِذَا سَجَىٰ",
      "translation": "and the night when it grows still and dark.",
      "juz": 30,
      "page": 596,
      "ruku": 535,
      "sajda": false
    },
    {
      "number": 6082,
      "numberInSurah": 3,
      "text": "مَا وَدَّعَكَ رَبُّكَ وَمَا قَلَىٰ",
      "translation": "Thy Sustainer has not forsaken thee, nor does He scorn thee:",
      "juz": 30,
      "page": 596,
      "ruku": 535,
      "sajda": false
    },
    {
      "number": 6083,
      "numberInSurah": 4,
      "text": "وَلَلْءَاخِرَةُ خَيْرٌۭ لَّكَ مِنَ ٱلْأُولَىٰ",
      "translation": "for, indeed, the life to come will be better for thee than this earlier part [of thy life]!",
      "juz": 30,
      "page": 596,
      "ruku": 535,
      "sajda": false
    },
    {
      "number": 6084,
      "numberInSurah": 5,
      "text": "وَلَسَوْفَ يُعْطِيكَ رَبُّكَ فَتَرْضَىٰٓ",
      "translation": "And, indeed, in time will thy Sustainer grant thee [what thy heart desires], and thou shalt be well-pleased.",
      "juz": 30,
      "page": 596,
      "ruku": 535,
      "sajda": false
    },
    {
      "number": 6085,
      "numberInSurah": 6,
      "text": "أَلَمْ يَجِدْكَ يَتِيمًۭا فَـَٔاوَىٰ",
      "translation": "Has He not found thee an orphan, and given thee shelter?",
      "juz": 30,
      "page": 596,
      "ruku": 535,
      "sajda": false
    },
    {
      "number": 6086,
      "numberInSurah": 7,
      "text": "وَوَجَدَكَ ضَآلًّۭا فَهَدَىٰ",
      "translation": "And found thee lost on thy way, and guided thee?",
      "juz": 30,
      "page": 596,
      "ruku": 535,
      "sajda": false
    },
    {
      "number": 6087,
      "numberInSurah": 8,
      "text": "وَوَجَدَكَ عَآئِلًۭا فَأَغْنَىٰ",
      "translation": "And found thee in want, and given thee sufficiency?",
      "juz": 30,
      "page": 596,
      "ruku": 535,
      "sajda": false
    },
    {
      "number": 6088,
      "numberInSurah": 9,
      "text": "فَأَمَّا ٱلْيَتِيمَ فَلَا تَقْهَرْ",
      "translation": "Therefore, the orphan shalt thou never wrong,",
      "juz": 30,
      "page": 596,
      "ruku": 535,
      "sajda": false
    },
    {
      "number": 6089,
      "numberInSurah": 10,
      "text": "وَأَمَّا ٱلسَّآئِلَ فَلَا تَنْهَرْ",
      "translation": "and him that seeks [thy] help shalt thou never chide,",
      "juz": 30,
      "page": 596,
      "ruku": 535,
      "sajda": false
    },
    {
      "number": 6090,
      "numberInSurah": 11,
      "text": "وَأَمَّا بِنِعْمَةِ رَبِّكَ فَحَدِّثْ",
      "translation": "and of thy Sustainer's blessings shalt thou [ever] speak.",
      "juz": 30,
      "page": 596,
      "ruku": 535,
      "sajda": false
    }
  ]
}