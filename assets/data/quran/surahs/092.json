{
  "number": 92,
  "name": "سُورَةُ اللَّيۡلِ",
  "englishName": "Al-Lail",
  "englishNameTranslation": "The Night",
  "revelationType": "Meccan",
  "numberOfAyahs": 21,
  "ayahs": [
    {
      "number": 6059,
      "numberInSurah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلَّيْلِ إِذَا يَغْشَىٰ",
      "translation": "CONSIDER the night as it veils [the earth] in darkness,",
      "juz": 30,
      "page": 595,
      "ruku": 534,
      "sajda": false
    },
    {
      "number": 6060,
      "numberInSurah": 2,
      "text": "وَٱلنَّهَارِ إِذَا تَجَلَّىٰ",
      "translation": "and the day as it rises bright!",
      "juz": 30,
      "page": 595,
      "ruku": 534,
      "sajda": false
    },
    {
      "number": 6061,
      "numberInSurah": 3,
      "text": "وَمَا خَلَقَ ٱلذَّكَرَ وَٱلْأُنثَىٰٓ",
      "translation": "Consider the creation of the male and the female!",
      "juz": 30,
      "page": 595,
      "ruku": 534,
      "sajda": false
    },
    {
      "number": 6062,
      "numberInSurah": 4,
      "text": "إِنَّ سَعْيَكُمْ لَشَتَّىٰ",
      "translation": "Verily, [O men,] you aim at most divergent ends!",
      "juz": 30,
      "page": 595,
      "ruku": 534,
      "sajda": false
    },
    {
      "number": 6063,
      "numberInSurah": 5,
      "text": "فَأَمَّا مَنْ أَعْطَىٰ وَٱتَّقَىٰ",
      "translation": "Thus, as for him who gives [to others] and is conscious of God,",
      "juz": 30,
      "page": 595,
      "ruku": 534,
      "sajda": false
    },
    {
      "number": 6064,
      "numberInSurah": 6,
      "text": "وَصَدَّقَ بِٱلْحُسْنَىٰ",
      "translation": "and believes in the truth of the ultimate good",
      "juz": 30,
      "page": 595,
      "ruku": 534,
      "sajda": false
    },
    {
      "number": 6065,
      "numberInSurah": 7,
      "text": "فَسَنُيَسِّرُهُۥ لِلْيُسْرَىٰ",
      "translation": "for him shall We make easy the path towards [ultimate] ease.",
      "juz": 30,
      "page": 595,
      "ruku": 534,
      "sajda": false
    },
    {
      "number": 6066,
      "numberInSurah": 8,
      "text": "وَأَمَّا مَنۢ بَخِلَ وَٱسْتَغْنَىٰ",
      "translation": "But as for him who is niggardly, and thinks that he is self-sufficient,",
      "juz": 30,
      "page": 595,
      "ruku": 534,
      "sajda": false
    },
    {
      "number": 6067,
      "numberInSurah": 9,
      "text": "وَكَذَّبَ بِٱلْحُسْنَىٰ",
      "translation": "and calls the ultimate good a lie –",
      "juz": 30,
      "page": 595,
      "ruku": 534,
      "sajda": false
    },
    {
      "number": 6068,
      "numberInSurah": 10,
      "text": "فَسَنُيَسِّرُهُۥ لِلْعُسْرَىٰ",
      "translation": "for him shall We make easy the path towards hardship:",
      "juz": 30,
      "page": 595,
      "ruku": 534,
      "sajda": false
    },
    {
      "number": 6069,
      "numberInSurah": 11,
      "text": "وَمَا يُغْنِى عَنْهُ مَالُهُۥٓ إِذَا تَرَدَّىٰٓ",
      "translation": "and what will his wealth avail him when he goes down [to his grave]?",
      "juz": 30,
      "page": 595,
      "ruku": 534,
      "sajda": false
    },
    {
      "number": 6070,
      "numberInSurah": 12,
      "text": "إِنَّ عَلَيْنَا لَلْهُدَىٰ",
      "translation": "BEHOLD, it is indeed for Us to grace [you] with guidance;",
      "juz": 30,
      "page": 595,
      "ruku": 534,
      "sajda": false
    },
    {
      "number": 6071,
      "numberInSurah": 13,
      "text": "وَإِنَّ لَنَا لَلْءَاخِرَةَ وَٱلْأُولَىٰ",
      "translation": "and, behold, Ours is [the dominion over] the life to come as well as [over] this earlier part [of your life]:",
      "juz": 30,
      "page": 595,
      "ruku": 534,
      "sajda": false
    },
    {
      "number": 6072,
      "numberInSurah": 14,
      "text": "فَأَنذَرْتُكُمْ نَارًۭا تَلَظَّىٰ",
      "translation": "and so I warn you of the raging fire -",
      "juz": 30,
      "page": 595,
      "ruku": 534,
      "sajda": false
    },
    {
      "number": 6073,
      "numberInSurah": 15,
      "text": "لَا يَصْلَىٰهَآ إِلَّا ٱلْأَشْقَى",
      "translation": "[the fire] which none shall have to endure but that most hapless wretch",
      "juz": 30,
      "page": 596,
      "ruku": 534,
      "sajda": false
    },
    {
      "number": 6074,
      "numberInSurah": 16,
      "text": "ٱلَّذِى كَذَّبَ وَتَوَلَّىٰ",
      "translation": "who gives the lie to the truth and turns away [from it].",
      "juz": 30,
      "page": 596,
      "ruku": 534,
      "sajda": false
    },
    {
      "number": 6075,
      "numberInSurah": 17,
      "text": "وَسَيُجَنَّبُهَا ٱلْأَتْقَى",
      "translation": "For, distant from it shall remain he who is truly conscious of God:",
      "juz": 30,
      "page": 596,
      "ruku": 534,
      "sajda": false
    },
    {
      "number": 6076,
      "numberInSurah": 18,
      "text": "ٱلَّذِى يُؤْتِى مَالَهُۥ يَتَزَكَّىٰ",
      "translation": "he that spends his possessions [on others] so that he might grow in purity –",
      "juz": 30,
      "page": 596,
      "ruku": 534,
      "sajda": false
    },
    {
      "number": 6077,
      "numberInSurah": 19,
      "text": "وَمَا لِأَحَدٍ عِندَهُۥ مِن نِّعْمَةٍۢ تُجْزَىٰٓ",
      "translation": "not as payment for favours received,",
      "juz": 30,
      "page": 596,
      "ruku": 534,
      "sajda": false
    },
    {
      "number": 6078,
      "numberInSurah": 20,
      "text": "إِلَّا ٱبْتِغَآءَ وَجْهِ رَبِّهِ ٱلْأَعْلَىٰ",
      "translation": "but only out of a longing for the countenance of his Sustainer, the All-Highest:",
      "juz": 30,
      "page": 596,
      "ruku": 534,
      "sajda": false
    },
    {
      "number": 6079,
      "numberInSurah": 21,
      "text": "وَلَسَوْفَ يَرْضَىٰ",
      "translation": "and such, indeed, shall in time be well-pleased.",
      "juz": 30,
      "page": 596,
      "ruku": 534,
      "sajda": false
    }
  ]
}