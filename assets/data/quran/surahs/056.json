{
  "number": 56,
  "name": "سُورَةُ الوَاقِعَةِ",
  "englishName": "Al-Waaqia",
  "englishNameTranslation": "The Inevitable",
  "revelationType": "Meccan",
  "numberOfAyahs": 96,
  "ayahs": [
    {
      "number": 4980,
      "numberInSurah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ إِذَا وَقَعَتِ ٱلْوَاقِعَةُ",
      "translation": "WHEN THAT which must come to pass [at last] comes to pass,",
      "juz": 27,
      "page": 534,
      "ruku": 469,
      "sajda": false
    },
    {
      "number": 4981,
      "numberInSurah": 2,
      "text": "لَيْسَ لِوَقْعَتِهَا كَاذِبَةٌ",
      "translation": "there will be nought that could give the lie to its having come to pass,",
      "juz": 27,
      "page": 534,
      "ruku": 469,
      "sajda": false
    },
    {
      "number": 4982,
      "numberInSurah": 3,
      "text": "خَافِضَةٌۭ رَّافِعَةٌ",
      "translation": "abasing [some], exalting [others]!",
      "juz": 27,
      "page": 534,
      "ruku": 469,
      "sajda": false
    },
    {
      "number": 4983,
      "numberInSurah": 4,
      "text": "إِذَا رُجَّتِ ٱلْأَرْضُ رَجًّۭا",
      "translation": "When the earth is shaken with a shaking [severe],",
      "juz": 27,
      "page": 534,
      "ruku": 469,
      "sajda": false
    },
    {
      "number": 4984,
      "numberInSurah": 5,
      "text": "وَبُسَّتِ ٱلْجِبَالُ بَسًّۭا",
      "translation": "and the mountains are shattered into [countless] shards,",
      "juz": 27,
      "page": 534,
      "ruku": 469,
      "sajda": false
    },
    {
      "number": 4985,
      "numberInSurah": 6,
      "text": "فَكَانَتْ هَبَآءًۭ مُّنۢبَثًّۭا",
      "translation": "so that they become as scat­tered dust –",
      "juz": 27,
      "page": 534,
      "ruku": 469,
      "sajda": false
    },
    {
      "number": 4986,
      "numberInSurah": 7,
      "text": "وَكُنتُمْ أَزْوَٰجًۭا ثَلَٰثَةًۭ",
      "translation": "[on that Day,] then, shall you be [divided into] three kinds.",
      "juz": 27,
      "page": 534,
      "ruku": 469,
      "sajda": false
    },
    {
      "number": 4987,
      "numberInSurah": 8,
      "text": "فَأَصْحَٰبُ ٱلْمَيْمَنَةِ مَآ أَصْحَٰبُ ٱلْمَيْمَنَةِ",
      "translation": "Thus, there shall be such as will have attained to what is right: oh, how [happy] will be they who have attained to what is right!",
      "juz": 27,
      "page": 534,
      "ruku": 469,
      "sajda": false
    },
    {
      "number": 4988,
      "numberInSurah": 9,
      "text": "وَأَصْحَٰبُ ٱلْمَشْـَٔمَةِ مَآ أَصْحَٰبُ ٱلْمَشْـَٔمَةِ",
      "translation": "And there shall be such as will have lost them­selves in evil: oh, how [unhappy] will be they who have lost themselves in evil!",
      "juz": 27,
      "page": 534,
      "ruku": 469,
      "sajda": false
    },
    {
      "number": 4989,
      "numberInSurah": 10,
      "text": "وَٱلسَّٰبِقُونَ ٱلسَّٰبِقُونَ",
      "translation": "But the foremost shall be [they who in life were] the foremost [in faith and good works]:",
      "juz": 27,
      "page": 534,
      "ruku": 469,
      "sajda": false
    },
    {
      "number": 4990,
      "numberInSurah": 11,
      "text": "أُو۟لَٰٓئِكَ ٱلْمُقَرَّبُونَ",
      "translation": "they who were [always] drawn close unto God!",
      "juz": 27,
      "page": 534,
      "ruku": 469,
      "sajda": false
    },
    {
      "number": 4991,
      "numberInSurah": 12,
      "text": "فِى جَنَّٰتِ ٱلنَّعِيمِ",
      "translation": "In gardens of bliss [will they dwell] -",
      "juz": 27,
      "page": 534,
      "ruku": 469,
      "sajda": false
    },
    {
      "number": 4992,
      "numberInSurah": 13,
      "text": "ثُلَّةٌۭ مِّنَ ٱلْأَوَّلِينَ",
      "translation": "a good many of those of olden times,",
      "juz": 27,
      "page": 534,
      "ruku": 469,
      "sajda": false
    },
    {
      "number": 4993,
      "numberInSurah": 14,
      "text": "وَقَلِيلٌۭ مِّنَ ٱلْءَاخِرِينَ",
      "translation": "but [only] a few of later times.",
      "juz": 27,
      "page": 534,
      "ruku": 469,
      "sajda": false
    },
    {
      "number": 4994,
      "numberInSurah": 15,
      "text": "عَلَىٰ سُرُرٍۢ مَّوْضُونَةٍۢ",
      "translation": "[They will be seated] on gold-encrusted thrones of happiness,",
      "juz": 27,
      "page": 534,
      "ruku": 469,
      "sajda": false
    },
    {
      "number": 4995,
      "numberInSurah": 16,
      "text": "مُّتَّكِـِٔينَ عَلَيْهَا مُتَقَٰبِلِينَ",
      "translation": "reclining upon them, facing one another [in love].",
      "juz": 27,
      "page": 534,
      "ruku": 469,
      "sajda": false
    },
    {
      "number": 4996,
      "numberInSurah": 17,
      "text": "يَطُوفُ عَلَيْهِمْ وِلْدَٰنٌۭ مُّخَلَّدُونَ",
      "translation": "Immortal youths will wait upon them",
      "juz": 27,
      "page": 535,
      "ruku": 469,
      "sajda": false
    },
    {
      "number": 4997,
      "numberInSurah": 18,
      "text": "بِأَكْوَابٍۢ وَأَبَارِيقَ وَكَأْسٍۢ مِّن مَّعِينٍۢ",
      "translation": "with goblets, and ewers, and cups filled with water from unsullied springs",
      "juz": 27,
      "page": 535,
      "ruku": 469,
      "sajda": false
    },
    {
      "number": 4998,
      "numberInSurah": 19,
      "text": "لَّا يُصَدَّعُونَ عَنْهَا وَلَا يُنزِفُونَ",
      "translation": "by which their minds will not be clouded and which will not make them drunk;",
      "juz": 27,
      "page": 535,
      "ruku": 469,
      "sajda": false
    },
    {
      "number": 4999,
      "numberInSurah": 20,
      "text": "وَفَٰكِهَةٍۢ مِّمَّا يَتَخَيَّرُونَ",
      "translation": "and with fruit of any kind that they may choose,",
      "juz": 27,
      "page": 535,
      "ruku": 469,
      "sajda": false
    },
    {
      "number": 5000,
      "numberInSurah": 21,
      "text": "وَلَحْمِ طَيْرٍۢ مِّمَّا يَشْتَهُونَ",
      "translation": "and with the flesh of any fowl that they may desire.",
      "juz": 27,
      "page": 535,
      "ruku": 469,
      "sajda": false
    },
    {
      "number": 5001,
      "numberInSurah": 22,
      "text": "وَحُورٌ عِينٌۭ",
      "translation": "And [with them will be their] companions pure, most beautiful of eye,",
      "juz": 27,
      "page": 535,
      "ruku": 469,
      "sajda": false
    },
    {
      "number": 5002,
      "numberInSurah": 23,
      "text": "كَأَمْثَٰلِ ٱللُّؤْلُؤِ ٱلْمَكْنُونِ",
      "translation": "like unto pearls [still] hidden in their shells.",
      "juz": 27,
      "page": 535,
      "ruku": 469,
      "sajda": false
    },
    {
      "number": 5003,
      "numberInSurah": 24,
      "text": "جَزَآءًۢ بِمَا كَانُوا۟ يَعْمَلُونَ",
      "translation": "[And this will be] a reward for what they did [in life].",
      "juz": 27,
      "page": 535,
      "ruku": 469,
      "sajda": false
    },
    {
      "number": 5004,
      "numberInSurah": 25,
      "text": "لَا يَسْمَعُونَ فِيهَا لَغْوًۭا وَلَا تَأْثِيمًا",
      "translation": "No empty talk will they hear there, nor any call to sin,",
      "juz": 27,
      "page": 535,
      "ruku": 469,
      "sajda": false
    },
    {
      "number": 5005,
      "numberInSurah": 26,
      "text": "إِلَّا قِيلًۭا سَلَٰمًۭا سَلَٰمًۭا",
      "translation": "but only the tiding of inner soundness and peace.",
      "juz": 27,
      "page": 535,
      "ruku": 469,
      "sajda": false
    },
    {
      "number": 5006,
      "numberInSurah": 27,
      "text": "وَأَصْحَٰبُ ٱلْيَمِينِ مَآ أَصْحَٰبُ ٱلْيَمِينِ",
      "translation": "NOW AS FOR those who have attained to righteous­ness - what of those who have attained to righteous­ness?",
      "juz": 27,
      "page": 535,
      "ruku": 469,
      "sajda": false
    },
    {
      "number": 5007,
      "numberInSurah": 28,
      "text": "فِى سِدْرٍۢ مَّخْضُودٍۢ",
      "translation": "[They, too, will find themselves] amidst fruit- laden lote-trees,",
      "juz": 27,
      "page": 535,
      "ruku": 469,
      "sajda": false
    },
    {
      "number": 5008,
      "numberInSurah": 29,
      "text": "وَطَلْحٍۢ مَّنضُودٍۢ",
      "translation": "and acacias flower-clad,",
      "juz": 27,
      "page": 535,
      "ruku": 469,
      "sajda": false
    },
    {
      "number": 5009,
      "numberInSurah": 30,
      "text": "وَظِلٍّۢ مَّمْدُودٍۢ",
      "translation": "and shade extended,",
      "juz": 27,
      "page": 535,
      "ruku": 469,
      "sajda": false
    },
    {
      "number": 5010,
      "numberInSurah": 31,
      "text": "وَمَآءٍۢ مَّسْكُوبٍۢ",
      "translation": "and waters gushing,",
      "juz": 27,
      "page": 535,
      "ruku": 469,
      "sajda": false
    },
    {
      "number": 5011,
      "numberInSurah": 32,
      "text": "وَفَٰكِهَةٍۢ كَثِيرَةٍۢ",
      "translation": "and fruit abounding,",
      "juz": 27,
      "page": 535,
      "ruku": 469,
      "sajda": false
    },
    {
      "number": 5012,
      "numberInSurah": 33,
      "text": "لَّا مَقْطُوعَةٍۢ وَلَا مَمْنُوعَةٍۢ",
      "translation": "never-failing and never out of reach.",
      "juz": 27,
      "page": 535,
      "ruku": 469,
      "sajda": false
    },
    {
      "number": 5013,
      "numberInSurah": 34,
      "text": "وَفُرُشٍۢ مَّرْفُوعَةٍ",
      "translation": "And [with them will be their] spouses, raised high:",
      "juz": 27,
      "page": 535,
      "ruku": 469,
      "sajda": false
    },
    {
      "number": 5014,
      "numberInSurah": 35,
      "text": "إِنَّآ أَنشَأْنَٰهُنَّ إِنشَآءًۭ",
      "translation": "for, behold, We shall have brought them into being in a life renewed,",
      "juz": 27,
      "page": 535,
      "ruku": 469,
      "sajda": false
    },
    {
      "number": 5015,
      "numberInSurah": 36,
      "text": "فَجَعَلْنَٰهُنَّ أَبْكَارًا",
      "translation": "having resurrected them as virgins,",
      "juz": 27,
      "page": 535,
      "ruku": 469,
      "sajda": false
    },
    {
      "number": 5016,
      "numberInSurah": 37,
      "text": "عُرُبًا أَتْرَابًۭا",
      "translation": "full of love, well-matched",
      "juz": 27,
      "page": 535,
      "ruku": 469,
      "sajda": false
    },
    {
      "number": 5017,
      "numberInSurah": 38,
      "text": "لِّأَصْحَٰبِ ٱلْيَمِينِ",
      "translation": "with those who have attained to righteousness:",
      "juz": 27,
      "page": 535,
      "ruku": 469,
      "sajda": false
    },
    {
      "number": 5018,
      "numberInSurah": 39,
      "text": "ثُلَّةٌۭ مِّنَ ٱلْأَوَّلِينَ",
      "translation": "a good many of olden times,",
      "juz": 27,
      "page": 535,
      "ruku": 470,
      "sajda": false
    },
    {
      "number": 5019,
      "numberInSurah": 40,
      "text": "وَثُلَّةٌۭ مِّنَ ٱلْءَاخِرِينَ",
      "translation": "and a good many of later times.",
      "juz": 27,
      "page": 535,
      "ruku": 470,
      "sajda": false
    },
    {
      "number": 5020,
      "numberInSurah": 41,
      "text": "وَأَصْحَٰبُ ٱلشِّمَالِ مَآ أَصْحَٰبُ ٱلشِّمَالِ",
      "translation": "BUT AS FOR those who have persevered in evil - what of those who have persevered in evil?",
      "juz": 27,
      "page": 535,
      "ruku": 470,
      "sajda": false
    },
    {
      "number": 5021,
      "numberInSurah": 42,
      "text": "فِى سَمُومٍۢ وَحَمِيمٍۢ",
      "translation": "[They will find themselves] in the midst of scorching winds, and burning despair,",
      "juz": 27,
      "page": 535,
      "ruku": 470,
      "sajda": false
    },
    {
      "number": 5022,
      "numberInSurah": 43,
      "text": "وَظِلٍّۢ مِّن يَحْمُومٍۢ",
      "translation": "and the shadows of black smoke -",
      "juz": 27,
      "page": 535,
      "ruku": 470,
      "sajda": false
    },
    {
      "number": 5023,
      "numberInSurah": 44,
      "text": "لَّا بَارِدٍۢ وَلَا كَرِيمٍ",
      "translation": "[shadows] neither cooling nor soothing.",
      "juz": 27,
      "page": 535,
      "ruku": 470,
      "sajda": false
    },
    {
      "number": 5024,
      "numberInSurah": 45,
      "text": "إِنَّهُمْ كَانُوا۟ قَبْلَ ذَٰلِكَ مُتْرَفِينَ",
      "translation": "For, behold, in times gone by they were wont to abandon themselves wholly to the pursuit of pleasures,",
      "juz": 27,
      "page": 535,
      "ruku": 470,
      "sajda": false
    },
    {
      "number": 5025,
      "numberInSurah": 46,
      "text": "وَكَانُوا۟ يُصِرُّونَ عَلَى ٱلْحِنثِ ٱلْعَظِيمِ",
      "translation": "and would persist in heinous sinning,",
      "juz": 27,
      "page": 535,
      "ruku": 470,
      "sajda": false
    },
    {
      "number": 5026,
      "numberInSurah": 47,
      "text": "وَكَانُوا۟ يَقُولُونَ أَئِذَا مِتْنَا وَكُنَّا تُرَابًۭا وَعِظَٰمًا أَءِنَّا لَمَبْعُوثُونَ",
      "translation": "and would say, “What! After we have died and become mere dust and bones, shall we, forsooth, be raised from the dead? -",
      "juz": 27,
      "page": 535,
      "ruku": 470,
      "sajda": false
    },
    {
      "number": 5027,
      "numberInSurah": 48,
      "text": "أَوَءَابَآؤُنَا ٱلْأَوَّلُونَ",
      "translation": "and perhaps, too, our forebears of old?”",
      "juz": 27,
      "page": 535,
      "ruku": 470,
      "sajda": false
    },
    {
      "number": 5028,
      "numberInSurah": 49,
      "text": "قُلْ إِنَّ ٱلْأَوَّلِينَ وَٱلْءَاخِرِينَ",
      "translation": "Say: “Verily, those of olden times and those of later times",
      "juz": 27,
      "page": 535,
      "ruku": 470,
      "sajda": false
    },
    {
      "number": 5029,
      "numberInSurah": 50,
      "text": "لَمَجْمُوعُونَ إِلَىٰ مِيقَٰتِ يَوْمٍۢ مَّعْلُومٍۢ",
      "translation": "will indeed be gathered together at an appointed time on a Day known [only to God]:",
      "juz": 27,
      "page": 535,
      "ruku": 470,
      "sajda": false
    },
    {
      "number": 5030,
      "numberInSurah": 51,
      "text": "ثُمَّ إِنَّكُمْ أَيُّهَا ٱلضَّآلُّونَ ٱلْمُكَذِّبُونَ",
      "translation": "and then, verily, O you who have gone astray and called the truth a lie,",
      "juz": 27,
      "page": 536,
      "ruku": 470,
      "sajda": false
    },
    {
      "number": 5031,
      "numberInSurah": 52,
      "text": "لَءَاكِلُونَ مِن شَجَرٍۢ مِّن زَقُّومٍۢ",
      "translation": "you will indeed have to taste of the tree of deadly fruit,",
      "juz": 27,
      "page": 536,
      "ruku": 470,
      "sajda": false
    },
    {
      "number": 5032,
      "numberInSurah": 53,
      "text": "فَمَالِـُٔونَ مِنْهَا ٱلْبُطُونَ",
      "translation": "and will have to fill your bellies therewith,",
      "juz": 27,
      "page": 536,
      "ruku": 470,
      "sajda": false
    },
    {
      "number": 5033,
      "numberInSurah": 54,
      "text": "فَشَٰرِبُونَ عَلَيْهِ مِنَ ٱلْحَمِيمِ",
      "translation": "and will thereupon have to drink [many a draught] of burning despair -",
      "juz": 27,
      "page": 536,
      "ruku": 470,
      "sajda": false
    },
    {
      "number": 5034,
      "numberInSurah": 55,
      "text": "فَشَٰرِبُونَ شُرْبَ ٱلْهِيمِ",
      "translation": "drink it as the most insatiably thirsty camels drink!”",
      "juz": 27,
      "page": 536,
      "ruku": 470,
      "sajda": false
    },
    {
      "number": 5035,
      "numberInSurah": 56,
      "text": "هَٰذَا نُزُلُهُمْ يَوْمَ ٱلدِّينِ",
      "translation": "Such will be their welcome on Judgment Day!",
      "juz": 27,
      "page": 536,
      "ruku": 470,
      "sajda": false
    },
    {
      "number": 5036,
      "numberInSurah": 57,
      "text": "نَحْنُ خَلَقْنَٰكُمْ فَلَوْلَا تُصَدِّقُونَ",
      "translation": "WE who have created you, [O men:] why, then, do you not accept the truth?",
      "juz": 27,
      "page": 536,
      "ruku": 470,
      "sajda": false
    },
    {
      "number": 5037,
      "numberInSurah": 58,
      "text": "أَفَرَءَيْتُم مَّا تُمْنُونَ",
      "translation": "Have you ever considered that [seed] which you emit?",
      "juz": 27,
      "page": 536,
      "ruku": 470,
      "sajda": false
    },
    {
      "number": 5038,
      "numberInSurah": 59,
      "text": "ءَأَنتُمْ تَخْلُقُونَهُۥٓ أَمْ نَحْنُ ٱلْخَٰلِقُونَ",
      "translation": "Is it you who create it - or are We the source of its creation?",
      "juz": 27,
      "page": 536,
      "ruku": 470,
      "sajda": false
    },
    {
      "number": 5039,
      "numberInSurah": 60,
      "text": "نَحْنُ قَدَّرْنَا بَيْنَكُمُ ٱلْمَوْتَ وَمَا نَحْنُ بِمَسْبُوقِينَ",
      "translation": "We have [indeed] decreed that death shall be [ever-present] among you: but there is nothing to prevent Us",
      "juz": 27,
      "page": 536,
      "ruku": 470,
      "sajda": false
    },
    {
      "number": 5040,
      "numberInSurah": 61,
      "text": "عَلَىٰٓ أَن نُّبَدِّلَ أَمْثَٰلَكُمْ وَنُنشِئَكُمْ فِى مَا لَا تَعْلَمُونَ",
      "translation": "from changing the nature of your existence and bringing you into being [anew] in a manner [as yet] unknown to you.",
      "juz": 27,
      "page": 536,
      "ruku": 470,
      "sajda": false
    },
    {
      "number": 5041,
      "numberInSurah": 62,
      "text": "وَلَقَدْ عَلِمْتُمُ ٱلنَّشْأَةَ ٱلْأُولَىٰ فَلَوْلَا تَذَكَّرُونَ",
      "translation": "And [since] you are indeed aware of the [miracle of your] coming into being in the first instance - why, then, do you not bethink yourselves [of Us]?",
      "juz": 27,
      "page": 536,
      "ruku": 470,
      "sajda": false
    },
    {
      "number": 5042,
      "numberInSurah": 63,
      "text": "أَفَرَءَيْتُم مَّا تَحْرُثُونَ",
      "translation": "Have you ever considered the seed which you cast upon the soil?",
      "juz": 27,
      "page": 536,
      "ruku": 470,
      "sajda": false
    },
    {
      "number": 5043,
      "numberInSurah": 64,
      "text": "ءَأَنتُمْ تَزْرَعُونَهُۥٓ أَمْ نَحْنُ ٱلزَّٰرِعُونَ",
      "translation": "Is it you who cause it to grow - or are We the cause of its growth?",
      "juz": 27,
      "page": 536,
      "ruku": 470,
      "sajda": false
    },
    {
      "number": 5044,
      "numberInSurah": 65,
      "text": "لَوْ نَشَآءُ لَجَعَلْنَٰهُ حُطَٰمًۭا فَظَلْتُمْ تَفَكَّهُونَ",
      "translation": "[For,] were it Our will, We could indeed turn it into chaff, and you would be left to wonder [and to lament],",
      "juz": 27,
      "page": 536,
      "ruku": 470,
      "sajda": false
    },
    {
      "number": 5045,
      "numberInSurah": 66,
      "text": "إِنَّا لَمُغْرَمُونَ",
      "translation": "“Verily, we are ruined!",
      "juz": 27,
      "page": 536,
      "ruku": 470,
      "sajda": false
    },
    {
      "number": 5046,
      "numberInSurah": 67,
      "text": "بَلْ نَحْنُ مَحْرُومُونَ",
      "translation": "Nay, but we have been deprived [of our livelihood]!”",
      "juz": 27,
      "page": 536,
      "ruku": 470,
      "sajda": false
    },
    {
      "number": 5047,
      "numberInSurah": 68,
      "text": "أَفَرَءَيْتُمُ ٱلْمَآءَ ٱلَّذِى تَشْرَبُونَ",
      "translation": "Have you ever considered the water which you drink?",
      "juz": 27,
      "page": 536,
      "ruku": 470,
      "sajda": false
    },
    {
      "number": 5048,
      "numberInSurah": 69,
      "text": "ءَأَنتُمْ أَنزَلْتُمُوهُ مِنَ ٱلْمُزْنِ أَمْ نَحْنُ ٱلْمُنزِلُونَ",
      "translation": "Is it you who cause it to come down from the clouds - or are We the cause of its coming down?",
      "juz": 27,
      "page": 536,
      "ruku": 470,
      "sajda": false
    },
    {
      "number": 5049,
      "numberInSurah": 70,
      "text": "لَوْ نَشَآءُ جَعَلْنَٰهُ أُجَاجًۭا فَلَوْلَا تَشْكُرُونَ",
      "translation": "[It comes down sweet - but] were it Our will, We could make it burningly salty and bitter: why, then, do you not give thanks [unto Us]?",
      "juz": 27,
      "page": 536,
      "ruku": 470,
      "sajda": false
    },
    {
      "number": 5050,
      "numberInSurah": 71,
      "text": "أَفَرَءَيْتُمُ ٱلنَّارَ ٱلَّتِى تُورُونَ",
      "translation": "Have you ever considered the fire which you kindle?",
      "juz": 27,
      "page": 536,
      "ruku": 470,
      "sajda": false
    },
    {
      "number": 5051,
      "numberInSurah": 72,
      "text": "ءَأَنتُمْ أَنشَأْتُمْ شَجَرَتَهَآ أَمْ نَحْنُ ٱلْمُنشِـُٔونَ",
      "translation": "Is it you who have brought into being the tree that serves as its fuel - or are We the cause of its coming into being?",
      "juz": 27,
      "page": 536,
      "ruku": 470,
      "sajda": false
    },
    {
      "number": 5052,
      "numberInSurah": 73,
      "text": "نَحْنُ جَعَلْنَٰهَا تَذْكِرَةًۭ وَمَتَٰعًۭا لِّلْمُقْوِينَ",
      "translation": "It is We who have made it a means to remind [you of Us], and a comfort for all who are lost and hungry in the wilderness [of their lives].",
      "juz": 27,
      "page": 536,
      "ruku": 470,
      "sajda": false
    },
    {
      "number": 5053,
      "numberInSurah": 74,
      "text": "فَسَبِّحْ بِٱسْمِ رَبِّكَ ٱلْعَظِيمِ",
      "translation": "Extol, then, the limitless glory of thy Sus­tainer’s mighty name!",
      "juz": 27,
      "page": 536,
      "ruku": 470,
      "sajda": false
    },
    {
      "number": 5054,
      "numberInSurah": 75,
      "text": "۞ فَلَآ أُقْسِمُ بِمَوَٰقِعِ ٱلنُّجُومِ",
      "translation": "NAY, I call to witness the coming-down in parts [of this Qur’an]",
      "juz": 27,
      "page": 536,
      "ruku": 471,
      "sajda": false
    },
    {
      "number": 5055,
      "numberInSurah": 76,
      "text": "وَإِنَّهُۥ لَقَسَمٌۭ لَّوْ تَعْلَمُونَ عَظِيمٌ",
      "translation": "and, behold, this is indeed a most solemn affirmation, if you but knew it!",
      "juz": 27,
      "page": 536,
      "ruku": 471,
      "sajda": false
    },
    {
      "number": 5056,
      "numberInSurah": 77,
      "text": "إِنَّهُۥ لَقُرْءَانٌۭ كَرِيمٌۭ",
      "translation": "Behold, it is a truly noble discourse,",
      "juz": 27,
      "page": 537,
      "ruku": 471,
      "sajda": false
    },
    {
      "number": 5057,
      "numberInSurah": 78,
      "text": "فِى كِتَٰبٍۢ مَّكْنُونٍۢ",
      "translation": "[conveyed unto man] in a well-guarded divine writ",
