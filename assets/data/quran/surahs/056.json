      "page": 537,
      "ruku": 471,
      "sajda": false
    },
    {
      "number": 5058,
      "numberInSurah": 79,
      "text": "لَّا يَمَسُّهُۥٓ إِلَّا ٱلْمُطَهَّرُونَ",
