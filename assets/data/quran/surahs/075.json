{
  "number": 75,
  "name": "سُورَةُ القِيَامَةِ",
  "englishName": "Al-Qiyaama",
  "englishNameTranslation": "The Resurrection",
  "revelationType": "Meccan",
  "numberOfAyahs": 40,
  "ayahs": [
    {
      "number": 5552,
      "numberInSurah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ لَآ أُقْسِمُ بِيَوْمِ ٱلْقِيَٰمَةِ",
      "translation": "NAY! I call to witness the Day of Resurrection!",
      "juz": 29,
      "page": 577,
      "ruku": 512,
      "sajda": false
    },
    {
      "number": 5553,
      "numberInSurah": 2,
      "text": "وَلَآ أُقْسِمُ بِٱلنَّفْسِ ٱللَّوَّامَةِ",
      "translation": "But nay! I call to witness the accusing voice of man's own conscience!",
      "juz": 29,
      "page": 577,
      "ruku": 512,
      "sajda": false
    },
    {
      "number": 5554,
      "numberInSurah": 3,
      "text": "أَيَحْسَبُ ٱلْإِنسَٰنُ أَلَّن نَّجْمَعَ عِظَامَهُۥ",
      "translation": "Does man think that We cannot [resurrect him and] bring his bones together again?",
      "juz": 29,
      "page": 577,
      "ruku": 512,
      "sajda": false
    },
    {
      "number": 5555,
      "numberInSurah": 4,
      "text": "بَلَىٰ قَٰدِرِينَ عَلَىٰٓ أَن نُّسَوِّىَ بَنَانَهُۥ",
      "translation": "Yea indeed, We are able to make whole his very finger-tips!",
      "juz": 29,
      "page": 577,
      "ruku": 512,
      "sajda": false
    },
    {
      "number": 5556,
      "numberInSurah": 5,
      "text": "بَلْ يُرِيدُ ٱلْإِنسَٰنُ لِيَفْجُرَ أَمَامَهُۥ",
      "translation": "None the less man chooses to deny what lies ahead of him,",
      "juz": 29,
      "page": 577,
      "ruku": 512,
      "sajda": false
    },
    {
      "number": 5557,
      "numberInSurah": 6,
      "text": "يَسْـَٔلُ أَيَّانَ يَوْمُ ٱلْقِيَٰمَةِ",
      "translation": "asking [derisively], \"When is that Resurrection Day to be?\"",
      "juz": 29,
      "page": 577,
      "ruku": 512,
      "sajda": false
    },
    {
      "number": 5558,
      "numberInSurah": 7,
      "text": "فَإِذَا بَرِقَ ٱلْبَصَرُ",
      "translation": "But [on that Day,] when the eyesight is by fear confounded,",
      "juz": 29,
      "page": 577,
      "ruku": 512,
      "sajda": false
    },
    {
      "number": 5559,
      "numberInSurah": 8,
      "text": "وَخَسَفَ ٱلْقَمَرُ",
      "translation": "and the moon is darkened,",
      "juz": 29,
      "page": 577,
      "ruku": 512,
      "sajda": false
    },
    {
      "number": 5560,
      "numberInSurah": 9,
      "text": "وَجُمِعَ ٱلشَّمْسُ وَٱلْقَمَرُ",
      "translation": "and the sun and the moon are brought together",
      "juz": 29,
      "page": 577,
      "ruku": 512,
      "sajda": false
    },
    {
      "number": 5561,
      "numberInSurah": 10,
      "text": "يَقُولُ ٱلْإِنسَٰنُ يَوْمَئِذٍ أَيْنَ ٱلْمَفَرُّ",
      "translation": "on that Day will man exclaim \"Whither to flee?\"",
      "juz": 29,
      "page": 577,
      "ruku": 512,
      "sajda": false
    },
    {
      "number": 5562,
      "numberInSurah": 11,
      "text": "كَلَّا لَا وَزَرَ",
      "translation": "But nay: no refuge [for thee, O man]!",
      "juz": 29,
      "page": 577,
      "ruku": 512,
      "sajda": false
    },
    {
      "number": 5563,
      "numberInSurah": 12,
      "text": "إِلَىٰ رَبِّكَ يَوْمَئِذٍ ٱلْمُسْتَقَرُّ",
      "translation": "With thy Sustainer, on that Day, the journey's end will be!",
      "juz": 29,
      "page": 577,
      "ruku": 512,
      "sajda": false
    },
    {
      "number": 5564,
      "numberInSurah": 13,
      "text": "يُنَبَّؤُا۟ ٱلْإِنسَٰنُ يَوْمَئِذٍۭ بِمَا قَدَّمَ وَأَخَّرَ",
      "translation": "Man will be apprised, on that Day, of what he has done and what he has left undone:",
      "juz": 29,
      "page": 577,
      "ruku": 512,
      "sajda": false
    },
    {
      "number": 5565,
      "numberInSurah": 14,
      "text": "بَلِ ٱلْإِنسَٰنُ عَلَىٰ نَفْسِهِۦ بَصِيرَةٌۭ",
      "translation": "nay, but man shall against himself be an eye-witness,",
      "juz": 29,
      "page": 577,
      "ruku": 512,
      "sajda": false
    },
    {
      "number": 5566,
      "numberInSurah": 15,
      "text": "وَلَوْ أَلْقَىٰ مَعَاذِيرَهُۥ",
      "translation": "even though he may veil himself in excuses.",
      "juz": 29,
      "page": 577,
      "ruku": 512,
      "sajda": false
    },
    {
      "number": 5567,
      "numberInSurah": 16,
      "text": "لَا تُحَرِّكْ بِهِۦ لِسَانَكَ لِتَعْجَلَ بِهِۦٓ",
      "translation": "MOVE NOT thy tongue in haste, [repeating the words of the revelation:]",
      "juz": 29,
      "page": 577,
      "ruku": 512,
      "sajda": false
    },
    {
      "number": 5568,
      "numberInSurah": 17,
      "text": "إِنَّ عَلَيْنَا جَمْعَهُۥ وَقُرْءَانَهُۥ",
      "translation": "for, behold, it is for Us to gather it [in thy heart,] and to cause it to be read [as it ought to be read].",
      "juz": 29,
      "page": 577,
      "ruku": 512,
      "sajda": false
    },
    {
      "number": 5569,
      "numberInSurah": 18,
      "text": "فَإِذَا قَرَأْنَٰهُ فَٱتَّبِعْ قُرْءَانَهُۥ",
      "translation": "Thus, when We recite it, follow thou its wording [with all thy mind]:",
      "juz": 29,
      "page": 577,
      "ruku": 512,
      "sajda": false
    },
    {
      "number": 5570,
      "numberInSurah": 19,
      "text": "ثُمَّ إِنَّ عَلَيْنَا بَيَانَهُۥ",
      "translation": "and then, behold, it will be for Us to make its meaning clear.",
      "juz": 29,
      "page": 577,
      "ruku": 512,
      "sajda": false
    },
    {
      "number": 5571,
      "numberInSurah": 20,
      "text": "كَلَّا بَلْ تُحِبُّونَ ٱلْعَاجِلَةَ",
      "translation": "NAY, but [most of] you love this fleeting life,",
      "juz": 29,
      "page": 578,
      "ruku": 512,
      "sajda": false
    },
    {
      "number": 5572,
      "numberInSurah": 21,
      "text": "وَتَذَرُونَ ٱلْءَاخِرَةَ",
      "translation": "and give no thought to the life to come [and to Judgment Day]!",
      "juz": 29,
      "page": 578,
      "ruku": 512,
      "sajda": false
    },
    {
      "number": 5573,
      "numberInSurah": 22,
      "text": "وُجُوهٌۭ يَوْمَئِذٍۢ نَّاضِرَةٌ",
      "translation": "Some faces will on that Day be bright with happiness,",
      "juz": 29,
      "page": 578,
      "ruku": 512,
      "sajda": false
    },
    {
      "number": 5574,
      "numberInSurah": 23,
      "text": "إِلَىٰ رَبِّهَا نَاظِرَةٌۭ",
      "translation": "looking up to their Sustainer;",
      "juz": 29,
      "page": 578,
      "ruku": 512,
      "sajda": false
    },
    {
      "number": 5575,
      "numberInSurah": 24,
      "text": "وَوُجُوهٌۭ يَوْمَئِذٍۭ بَاسِرَةٌۭ",
      "translation": "and some faces will on that Day be overcast with despair,",
      "juz": 29,
      "page": 578,
      "ruku": 512,
      "sajda": false
    },
    {
      "number": 5576,
      "numberInSurah": 25,
      "text": "تَظُنُّ أَن يُفْعَلَ بِهَا فَاقِرَةٌۭ",
      "translation": "knowing that a crushing calamity is about to befall them.",
      "juz": 29,
      "page": 578,
      "ruku": 512,
      "sajda": false
    },
    {
      "number": 5577,
      "numberInSurah": 26,
      "text": "كَلَّآ إِذَا بَلَغَتِ ٱلتَّرَاقِىَ",
      "translation": "NAY, but when [the last breath] comes up to the throat [of a dying man],",
      "juz": 29,
      "page": 578,
      "ruku": 512,
      "sajda": false
    },
    {
      "number": 5578,
      "numberInSurah": 27,
      "text": "وَقِيلَ مَنْ ۜ رَاقٍۢ",
      "translation": "and people ask, \"Is there any wizard [that could save him]?\"",
      "juz": 29,
      "page": 578,
      "ruku": 512,
      "sajda": false
    },
    {
      "number": 5579,
      "numberInSurah": 28,
      "text": "وَظَنَّ أَنَّهُ ٱلْفِرَاقُ",
      "translation": "the while he [himself] knows that this is the parting,",
      "juz": 29,
      "page": 578,
      "ruku": 512,
      "sajda": false
    },
    {
      "number": 5580,
      "numberInSurah": 29,
      "text": "وَٱلْتَفَّتِ ٱلسَّاقُ بِٱلسَّاقِ",
      "translation": "and is enwrapped in the pangs of death",
      "juz": 29,
      "page": 578,
      "ruku": 512,
      "sajda": false
    },
    {
      "number": 5581,
      "numberInSurah": 30,
      "text": "إِلَىٰ رَبِّكَ يَوْمَئِذٍ ٱلْمَسَاقُ",
      "translation": "at that time towards thy Sustainer does he feel impelled to turn!",
      "juz": 29,
      "page": 578,
      "ruku": 512,
      "sajda": false
    },
    {
      "number": 5582,
      "numberInSurah": 31,
      "text": "فَلَا صَدَّقَ وَلَا صَلَّىٰ",
      "translation": "[Useless, though, will be his repentance: for [as long as he was alive] he did not accept the truth, nor did he pray [for enlightenment],",
      "juz": 29,
      "page": 578,
      "ruku": 513,
      "sajda": false
    },
    {
      "number": 5583,
      "numberInSurah": 32,
      "text": "وَلَٰكِن كَذَّبَ وَتَوَلَّىٰ",
      "translation": "but, on the contrary, he gave the lie to the truth and turned away [from it],",
      "juz": 29,
      "page": 578,
      "ruku": 513,
      "sajda": false
    },
    {
      "number": 5584,
      "numberInSurah": 33,
      "text": "ثُمَّ ذَهَبَ إِلَىٰٓ أَهْلِهِۦ يَتَمَطَّىٰٓ",
      "translation": "and then went arrogantly back to what he had come from.",
      "juz": 29,
      "page": 578,
      "ruku": 513,
      "sajda": false
    },
    {
      "number": 5585,
      "numberInSurah": 34,
      "text": "أَوْلَىٰ لَكَ فَأَوْلَىٰ",
      "translation": "[And yet, O man, thine end comes hourly] nearer unto thee, and nearer –",
      "juz": 29,
      "page": 578,
      "ruku": 513,
      "sajda": false
    },
    {
      "number": 5586,
      "numberInSurah": 35,
      "text": "ثُمَّ أَوْلَىٰ لَكَ فَأَوْلَىٰٓ",
      "translation": "and ever nearer unto thee, and nearer!",
      "juz": 29,
      "page": 578,
      "ruku": 513,
      "sajda": false
    },
    {
      "number": 5587,
      "numberInSurah": 36,
      "text": "أَيَحْسَبُ ٱلْإِنسَٰنُ أَن يُتْرَكَ سُدًى",
      "translation": "DOES MAN, then, think that he is to be left to himself to go about at will?",
      "juz": 29,
      "page": 578,
      "ruku": 513,
      "sajda": false
    },
    {
      "number": 5588,
      "numberInSurah": 37,
      "text": "أَلَمْ يَكُ نُطْفَةًۭ مِّن مَّنِىٍّۢ يُمْنَىٰ",
      "translation": "Was he not once a [mere] drop of sperm that had been spilt,",
      "juz": 29,
      "page": 578,
      "ruku": 513,
      "sajda": false
    },
    {
      "number": 5589,
      "numberInSurah": 38,
      "text": "ثُمَّ كَانَ عَلَقَةًۭ فَخَلَقَ فَسَوَّىٰ",
      "translation": "and thereafter became a germ-cell - whereupon He created and formed [it] in accordance with what [it] was meant to be,",
      "juz": 29,
      "page": 578,
      "ruku": 513,
      "sajda": false
    },
    {
      "number": 5590,
      "numberInSurah": 39,
      "text": "فَجَعَلَ مِنْهُ ٱلزَّوْجَيْنِ ٱلذَّكَرَ وَٱلْأُنثَىٰٓ",
      "translation": "and fashioned out of it the two sexes, the male and the female?",
      "juz": 29,
      "page": 578,
      "ruku": 513,
      "sajda": false
    },
    {
      "number": 5591,
      "numberInSurah": 40,
      "text": "أَلَيْسَ ذَٰلِكَ بِقَٰدِرٍ عَلَىٰٓ أَن يُحْۦِىَ ٱلْمَوْتَىٰ",
      "translation": "Is not He, then; able to bring the dead back to life?",
      "juz": 29,
      "page": 578,
      "ruku": 513,
      "sajda": false
    }
  ]
}