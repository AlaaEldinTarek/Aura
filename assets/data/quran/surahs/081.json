{
  "number": 81,
  "name": "سُورَةُ التَّكۡوِيرِ",
  "englishName": "At-Takwir",
  "englishNameTranslation": "The Overthrowing",
  "revelationType": "Meccan",
  "numberOfAyahs": 29,
  "ayahs": [
    {
      "number": 5801,
      "numberInSurah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ إِذَا ٱلشَّمْسُ كُوِّرَتْ",
      "translation": "WHEN THE SUN is shrouded in darkness,",
      "juz": 30,
      "page": 586,
      "ruku": 523,
      "sajda": false
    },
    {
      "number": 5802,
      "numberInSurah": 2,
      "text": "وَإِذَا ٱلنُّجُومُ ٱنكَدَرَتْ",
      "translation": "and when the stars lose their light,",
      "juz": 30,
      "page": 586,
      "ruku": 523,
      "sajda": false
    },
    {
      "number": 5803,
      "numberInSurah": 3,
      "text": "وَإِذَا ٱلْجِبَالُ سُيِّرَتْ",
      "translation": "and when the mountains are made to vanish,",
      "juz": 30,
      "page": 586,
      "ruku": 523,
      "sajda": false
    },
    {
      "number": 5804,
      "numberInSurah": 4,
      "text": "وَإِذَا ٱلْعِشَارُ عُطِّلَتْ",
      "translation": "and when she-camels big with young, about to give birth, are left untended,",
      "juz": 30,
      "page": 586,
      "ruku": 523,
      "sajda": false
    },
    {
      "number": 5805,
      "numberInSurah": 5,
      "text": "وَإِذَا ٱلْوُحُوشُ حُشِرَتْ",
      "translation": "and when all beasts are gathered together,",
      "juz": 30,
      "page": 586,
      "ruku": 523,
      "sajda": false
    },
    {
      "number": 5806,
      "numberInSurah": 6,
      "text": "وَإِذَا ٱلْبِحَارُ سُجِّرَتْ",
      "translation": "and when the seas boil over,",
      "juz": 30,
      "page": 586,
      "ruku": 523,
      "sajda": false
    },
    {
      "number": 5807,
      "numberInSurah": 7,
      "text": "وَإِذَا ٱلنُّفُوسُ زُوِّجَتْ",
      "translation": "and when all human beings are coupled [with their deeds],",
      "juz": 30,
      "page": 586,
      "ruku": 523,
      "sajda": false
    },
    {
      "number": 5808,
      "numberInSurah": 8,
      "text": "وَإِذَا ٱلْمَوْءُۥدَةُ سُئِلَتْ",
      "translation": "and when the girl-child that was buried alive is made to ask",
      "juz": 30,
      "page": 586,
      "ruku": 523,
      "sajda": false
    },
    {
      "number": 5809,
      "numberInSurah": 9,
      "text": "بِأَىِّ ذَنۢبٍۢ قُتِلَتْ",
      "translation": "for what crime she had been slain,",
      "juz": 30,
      "page": 586,
      "ruku": 523,
      "sajda": false
    },
    {
      "number": 5810,
      "numberInSurah": 10,
      "text": "وَإِذَا ٱلصُّحُفُ نُشِرَتْ",
      "translation": "and when the scrolls [of men's deeds] are unfolded,",
      "juz": 30,
      "page": 586,
      "ruku": 523,
      "sajda": false
    },
    {
      "number": 5811,
      "numberInSurah": 11,
      "text": "وَإِذَا ٱلسَّمَآءُ كُشِطَتْ",
      "translation": "and when heaven is laid bare,",
      "juz": 30,
      "page": 586,
      "ruku": 523,
      "sajda": false
    },
    {
      "number": 5812,
      "numberInSurah": 12,
      "text": "وَإِذَا ٱلْجَحِيمُ سُعِّرَتْ",
      "translation": "and when the blazing fire [of hell] is kindled bright,",
      "juz": 30,
      "page": 586,
      "ruku": 523,
      "sajda": false
    },
    {
      "number": 5813,
      "numberInSurah": 13,
      "text": "وَإِذَا ٱلْجَنَّةُ أُزْلِفَتْ",
      "translation": "and when paradise is brought into view:",
      "juz": 30,
      "page": 586,
      "ruku": 523,
      "sajda": false
    },
    {
      "number": 5814,
      "numberInSurah": 14,
      "text": "عَلِمَتْ نَفْسٌۭ مَّآ أَحْضَرَتْ",
      "translation": "[on that Day] every human being will come to know what he has prepared [for himself].",
      "juz": 30,
      "page": 586,
      "ruku": 523,
      "sajda": false
    },
    {
      "number": 5815,
      "numberInSurah": 15,
      "text": "فَلَآ أُقْسِمُ بِٱلْخُنَّسِ",
      "translation": "BUT NAY! I call to witness the revolving stars,",
      "juz": 30,
      "page": 586,
      "ruku": 523,
      "sajda": false
    },
    {
      "number": 5816,
      "numberInSurah": 16,
      "text": "ٱلْجَوَارِ ٱلْكُنَّسِ",
      "translation": "the planets that run their course and set,",
      "juz": 30,
      "page": 586,
      "ruku": 523,
      "sajda": false
    },
    {
      "number": 5817,
      "numberInSurah": 17,
      "text": "وَٱلَّيْلِ إِذَا عَسْعَسَ",
      "translation": "and the night as it darkly falls,",
      "juz": 30,
      "page": 586,
      "ruku": 523,
      "sajda": false
    },
    {
      "number": 5818,
      "numberInSurah": 18,
      "text": "وَٱلصُّبْحِ إِذَا تَنَفَّسَ",
      "translation": "and the morn as it softly breathes:",
      "juz": 30,
      "page": 586,
      "ruku": 523,
      "sajda": false
    },
    {
      "number": 5819,
      "numberInSurah": 19,
      "text": "إِنَّهُۥ لَقَوْلُ رَسُولٍۢ كَرِيمٍۢ",
      "translation": "behold, this [divine writ] is indeed the [inspired] word of a noble apostle,",
      "juz": 30,
      "page": 586,
      "ruku": 523,
      "sajda": false
    },
    {
      "number": 5820,
      "numberInSurah": 20,
      "text": "ذِى قُوَّةٍ عِندَ ذِى ٱلْعَرْشِ مَكِينٍۢ",
      "translation": "with strength endowed, secure with Him who in almightiness is enthroned",
      "juz": 30,
      "page": 586,
      "ruku": 523,
      "sajda": false
    },
    {
      "number": 5821,
      "numberInSurah": 21,
      "text": "مُّطَاعٍۢ ثَمَّ أَمِينٍۢ",
      "translation": "[the word] of one to be heeded, and worthy of trust!",
      "juz": 30,
      "page": 586,
      "ruku": 523,
      "sajda": false
    },
    {
      "number": 5822,
      "numberInSurah": 22,
      "text": "وَمَا صَاحِبُكُم بِمَجْنُونٍۢ",
      "translation": "For, this fellow-man of yours is not a madman:",
      "juz": 30,
      "page": 586,
      "ruku": 523,
      "sajda": false
    },
    {
      "number": 5823,
      "numberInSurah": 23,
      "text": "وَلَقَدْ رَءَاهُ بِٱلْأُفُقِ ٱلْمُبِينِ",
      "translation": "he truly beheld [the angel - beheld] him on the clear horizon;",
      "juz": 30,
      "page": 586,
      "ruku": 523,
      "sajda": false
    },
    {
      "number": 5824,
      "numberInSurah": 24,
      "text": "وَمَا هُوَ عَلَى ٱلْغَيْبِ بِضَنِينٍۢ",
      "translation": "and he is not one to begrudge others the knowledge [of whatever has been revealed to him] out of that which is beyond the reach of human Perception.",
      "juz": 30,
      "page": 586,
      "ruku": 523,
      "sajda": false
    },
    {
      "number": 5825,
      "numberInSurah": 25,
      "text": "وَمَا هُوَ بِقَوْلِ شَيْطَٰنٍۢ رَّجِيمٍۢ",
      "translation": "Nor is this [message] the word of any satanic force accursed.",
      "juz": 30,
      "page": 586,
      "ruku": 523,
      "sajda": false
    },
    {
      "number": 5826,
      "numberInSurah": 26,
      "text": "فَأَيْنَ تَذْهَبُونَ",
      "translation": "Whither, then, will you go?",
      "juz": 30,
      "page": 586,
      "ruku": 523,
      "sajda": false
    },
    {
      "number": 5827,
      "numberInSurah": 27,
      "text": "إِنْ هُوَ إِلَّا ذِكْرٌۭ لِّلْعَٰلَمِينَ",
      "translation": "This [message] is no less than a reminder to all mankind –",
      "juz": 30,
      "page": 586,
      "ruku": 523,
      "sajda": false
    },
    {
      "number": 5828,
      "numberInSurah": 28,
      "text": "لِمَن شَآءَ مِنكُمْ أَن يَسْتَقِيمَ",
      "translation": "to everyone of you who wills to walk a straight way.",
      "juz": 30,
      "page": 586,
      "ruku": 523,
      "sajda": false
    },
    {
      "number": 5829,
      "numberInSurah": 29,
      "text": "وَمَا تَشَآءُونَ إِلَّآ أَن يَشَآءَ ٱللَّهُ رَبُّ ٱلْعَٰلَمِينَ",
      "translation": "But you cannot will it unless God, the Sustainer of all the worlds, wills [to show you that way].",
      "juz": 30,
      "page": 586,
      "ruku": 523,
      "sajda": false
    }
  ]
}