{
  "number": 107,
  "name": "سُورَةُ المَاعُونِ",
  "englishName": "Al-Maa'un",
  "englishNameTranslation": "Almsgiving",
  "revelationType": "Meccan",
  "numberOfAyahs": 7,
  "ayahs": [
    {
      "number": 6198,
      "numberInSurah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ أَرَءَيْتَ ٱلَّذِى يُكَذِّبُ بِٱلدِّينِ",
      "translation": "HAST THOU ever considered [the kind of man] who gives the lie to all moral law?",
      "juz": 30,
      "page": 602,
      "ruku": 549,
      "sajda": false
    },
    {
      "number": 6199,
      "numberInSurah": 2,
      "text": "فَذَٰلِكَ ٱلَّذِى يَدُعُّ ٱلْيَتِيمَ",
      "translation": "Behold, it is this [kind of man] that thrusts the orphan away,",
      "juz": 30,
      "page": 602,
      "ruku": 549,
      "sajda": false
    },
    {
      "number": 6200,
      "numberInSurah": 3,
      "text": "وَلَا يَحُضُّ عَلَىٰ طَعَامِ ٱلْمِسْكِينِ",
      "translation": "and feels no urge to feed the needy.",
      "juz": 30,
      "page": 602,
      "ruku": 549,
      "sajda": false
    },
    {
      "number": 6201,
      "numberInSurah": 4,
      "text": "فَوَيْلٌۭ لِّلْمُصَلِّينَ",
      "translation": "Woe, then, unto those praying ones",
      "juz": 30,
      "page": 602,
      "ruku": 549,
      "sajda": false
    },
    {
      "number": 6202,
      "numberInSurah": 5,
      "text": "ٱلَّذِينَ هُمْ عَن صَلَاتِهِمْ سَاهُونَ",
      "translation": "whose hearts from their prayer are remote",
      "juz": 30,
      "page": 602,
      "ruku": 549,
      "sajda": false
    },
    {
      "number": 6203,
      "numberInSurah": 6,
      "text": "ٱلَّذِينَ هُمْ يُرَآءُونَ",
      "translation": "those who want only to be seen and praised,",
      "juz": 30,
      "page": 602,
      "ruku": 549,
      "sajda": false
    },
    {
      "number": 6204,
      "numberInSurah": 7,
      "text": "وَيَمْنَعُونَ ٱلْمَاعُونَ",
      "translation": "and, withal, deny all assistance [to their fellow-men]!",
      "juz": 30,
      "page": 602,
      "ruku": 549,
      "sajda": false
    }
  ]
}