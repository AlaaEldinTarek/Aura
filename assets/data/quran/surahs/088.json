{
  "number": 88,
  "name": "سُورَةُ الغَاشِيَةِ",
  "englishName": "Al-Ghaashiya",
  "englishNameTranslation": "The Overwhelming",
  "revelationType": "Meccan",
  "numberOfAyahs": 26,
  "ayahs": [
    {
      "number": 5968,
      "numberInSurah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ هَلْ أَتَىٰكَ حَدِيثُ ٱلْغَٰشِيَةِ",
      "translation": "HAS THERE COME unto thee the tiding of the Overshadowing Event?'",
      "juz": 30,
      "page": 592,
      "ruku": 530,
      "sajda": false
    },
    {
      "number": 5969,
      "numberInSurah": 2,
      "text": "وُجُوهٌۭ يَوْمَئِذٍ خَٰشِعَةٌ",
      "translation": "Some faces will on that Day be downcast,",
      "juz": 30,
      "page": 592,
      "ruku": 530,
      "sajda": false
    },
    {
      "number": 5970,
      "numberInSurah": 3,
      "text": "عَامِلَةٌۭ نَّاصِبَةٌۭ",
      "translation": "toiling [under burdens of sin], worn out [by fear],",
      "juz": 30,
      "page": 592,
      "ruku": 530,
      "sajda": false
    },
    {
      "number": 5971,
      "numberInSurah": 4,
      "text": "تَصْلَىٰ نَارًا حَامِيَةًۭ",
      "translation": "about to enter a glowing fire,",
      "juz": 30,
      "page": 592,
      "ruku": 530,
      "sajda": false
    },
    {
      "number": 5972,
      "numberInSurah": 5,
      "text": "تُسْقَىٰ مِنْ عَيْنٍ ءَانِيَةٍۢ",
      "translation": "given to drink from a boiling spring.",
      "juz": 30,
      "page": 592,
      "ruku": 530,
      "sajda": false
    },
    {
      "number": 5973,
      "numberInSurah": 6,
      "text": "لَّيْسَ لَهُمْ طَعَامٌ إِلَّا مِن ضَرِيعٍۢ",
      "translation": "No food for them save the bitterness of dry thorns,",
      "juz": 30,
      "page": 592,
      "ruku": 530,
      "sajda": false
    },
    {
      "number": 5974,
      "numberInSurah": 7,
      "text": "لَّا يُسْمِنُ وَلَا يُغْنِى مِن جُوعٍۢ",
      "translation": "which gives no strength and neither stills hunger.",
      "juz": 30,
      "page": 592,
      "ruku": 530,
      "sajda": false
    },
    {
      "number": 5975,
      "numberInSurah": 8,
      "text": "وُجُوهٌۭ يَوْمَئِذٍۢ نَّاعِمَةٌۭ",
      "translation": "[And] some faces will on that Day shine with bliss,",
      "juz": 30,
      "page": 592,
      "ruku": 530,
      "sajda": false
    },
    {
      "number": 5976,
      "numberInSurah": 9,
      "text": "لِّسَعْيِهَا رَاضِيَةٌۭ",
      "translation": "well-pleased with [the fruit of] their striving,",
      "juz": 30,
      "page": 592,
      "ruku": 530,
      "sajda": false
    },
    {
      "number": 5977,
      "numberInSurah": 10,
      "text": "فِى جَنَّةٍ عَالِيَةٍۢ",
      "translation": "in a garden sublime,",
      "juz": 30,
      "page": 592,
      "ruku": 530,
      "sajda": false
    },
    {
      "number": 5978,
      "numberInSurah": 11,
      "text": "لَّا تَسْمَعُ فِيهَا لَٰغِيَةًۭ",
      "translation": "wherein thou wilt hear no empty talk.",
      "juz": 30,
      "page": 592,
      "ruku": 530,
      "sajda": false
    },
    {
      "number": 5979,
      "numberInSurah": 12,
      "text": "فِيهَا عَيْنٌۭ جَارِيَةٌۭ",
      "translation": "Countless springs will flow therein,",
      "juz": 30,
      "page": 592,
      "ruku": 530,
      "sajda": false
    },
    {
      "number": 5980,
      "numberInSurah": 13,
      "text": "فِيهَا سُرُرٌۭ مَّرْفُوعَةٌۭ",
      "translation": "[and] there will be thrones [of happiness] raised high,",
      "juz": 30,
      "page": 592,
      "ruku": 530,
      "sajda": false
    },
    {
      "number": 5981,
      "numberInSurah": 14,
      "text": "وَأَكْوَابٌۭ مَّوْضُوعَةٌۭ",
      "translation": "and goblets placed ready,",
      "juz": 30,
      "page": 592,
      "ruku": 530,
      "sajda": false
    },
    {
      "number": 5982,
      "numberInSurah": 15,
      "text": "وَنَمَارِقُ مَصْفُوفَةٌۭ",
      "translation": "and cushions ranged,",
      "juz": 30,
      "page": 592,
      "ruku": 530,
      "sajda": false
    },
    {
      "number": 5983,
      "numberInSurah": 16,
      "text": "وَزَرَابِىُّ مَبْثُوثَةٌ",
      "translation": "and carpets spread out…",
      "juz": 30,
      "page": 592,
      "ruku": 530,
      "sajda": false
    },
    {
      "number": 5984,
      "numberInSurah": 17,
      "text": "أَفَلَا يَنظُرُونَ إِلَى ٱلْإِبِلِ كَيْفَ خُلِقَتْ",
      "translation": "DO, THEN, they [who deny resurrection] never gaze at the clouds pregnant with water, [and observe] how they are created?",
      "juz": 30,
      "page": 592,
      "ruku": 530,
      "sajda": false
    },
    {
      "number": 5985,
      "numberInSurah": 18,
      "text": "وَإِلَى ٱلسَّمَآءِ كَيْفَ رُفِعَتْ",
      "translation": "And at the sky, how it is raised aloft?",
      "juz": 30,
      "page": 592,
      "ruku": 530,
      "sajda": false
    },
    {
      "number": 5986,
      "numberInSurah": 19,
      "text": "وَإِلَى ٱلْجِبَالِ كَيْفَ نُصِبَتْ",
      "translation": "And at the mountains, how firmly they are reared?",
      "juz": 30,
      "page": 592,
      "ruku": 530,
      "sajda": false
    },
    {
      "number": 5987,
      "numberInSurah": 20,
      "text": "وَإِلَى ٱلْأَرْضِ كَيْفَ سُطِحَتْ",
      "translation": "And at the earth, how it is spread out?",
      "juz": 30,
      "page": 592,
      "ruku": 530,
      "sajda": false
    },
    {
      "number": 5988,
      "numberInSurah": 21,
      "text": "فَذَكِّرْ إِنَّمَآ أَنتَ مُذَكِّرٌۭ",
      "translation": "And so, [O Prophet,] exhort them; thy task is only to exhort:",
      "juz": 30,
      "page": 592,
      "ruku": 530,
      "sajda": false
    },
    {
      "number": 5989,
      "numberInSurah": 22,
      "text": "لَّسْتَ عَلَيْهِم بِمُصَيْطِرٍ",
      "translation": "thou canst not compel them [to believe].",
      "juz": 30,
      "page": 592,
      "ruku": 530,
      "sajda": false
    },
    {
      "number": 5990,
      "numberInSurah": 23,
      "text": "إِلَّا مَن تَوَلَّىٰ وَكَفَرَ",
      "translation": "However, as for him who turns away, being bent on denying the truth,",
      "juz": 30,
      "page": 592,
      "ruku": 530,
      "sajda": false
    },
    {
      "number": 5991,
      "numberInSurah": 24,
      "text": "فَيُعَذِّبُهُ ٱللَّهُ ٱلْعَذَابَ ٱلْأَكْبَرَ",
      "translation": "him will God cause to suffer the greatest suffering [in the life to come]:",
      "juz": 30,
      "page": 592,
      "ruku": 530,
      "sajda": false
    },
    {
      "number": 5992,
      "numberInSurah": 25,
      "text": "إِنَّ إِلَيْنَآ إِيَابَهُمْ",
      "translation": "for behold, unto Us will be their return,",
      "juz": 30,
      "page": 592,
      "ruku": 530,
      "sajda": false
    },
    {
      "number": 5993,
      "numberInSurah": 26,
      "text": "ثُمَّ إِنَّ عَلَيْنَا حِسَابَهُم",
      "translation": "and verily, It is for Us to call them to account.",
      "juz": 30,
      "page": 592,
      "ruku": 530,
      "sajda": false
    }
  ]
}