{
  "number": 86,
  "name": "سُورَةُ الطَّارِقِ",
  "englishName": "At-Taariq",
  "englishNameTranslation": "The Morning Star",
  "revelationType": "Meccan",
  "numberOfAyahs": 17,
  "ayahs": [
    {
      "number": 5932,
      "numberInSurah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلسَّمَآءِ وَٱلطَّارِقِ",
      "translation": "CONSIDER the heavens and that which comes in the night!",
      "juz": 30,
      "page": 591,
      "ruku": 528,
      "sajda": false
    },
    {
      "number": 5933,
      "numberInSurah": 2,
      "text": "وَمَآ أَدْرَىٰكَ مَا ٱلطَّارِقُ",
      "translation": "And what could make thee conceive what it is that comes in the night?",
      "juz": 30,
      "page": 591,
      "ruku": 528,
      "sajda": false
    },
    {
      "number": 5934,
      "numberInSurah": 3,
      "text": "ٱلنَّجْمُ ٱلثَّاقِبُ",
      "translation": "It is the star that pierces through [life's] darkness:",
      "juz": 30,
      "page": 591,
      "ruku": 528,
      "sajda": false
    },
    {
      "number": 5935,
      "numberInSurah": 4,
      "text": "إِن كُلُّ نَفْسٍۢ لَّمَّا عَلَيْهَا حَافِظٌۭ",
      "translation": "[for] no human being has ever been left unguarded.",
      "juz": 30,
      "page": 591,
      "ruku": 528,
      "sajda": false
    },
    {
      "number": 5936,
      "numberInSurah": 5,
      "text": "فَلْيَنظُرِ ٱلْإِنسَٰنُ مِمَّ خُلِقَ",
      "translation": "LET MAN, then, observe out of what he has been created:",
      "juz": 30,
      "page": 591,
      "ruku": 528,
      "sajda": false
    },
    {
      "number": 5937,
      "numberInSurah": 6,
      "text": "خُلِقَ مِن مَّآءٍۢ دَافِقٍۢ",
      "translation": "he has been created out of a seminal fluid",
      "juz": 30,
      "page": 591,
      "ruku": 528,
      "sajda": false
    },
    {
      "number": 5938,
      "numberInSurah": 7,
      "text": "يَخْرُجُ مِنۢ بَيْنِ ٱلصُّلْبِ وَٱلتَّرَآئِبِ",
      "translation": "issuing from between the loins [of man] and the pelvic arch [of woman].",
      "juz": 30,
      "page": 591,
      "ruku": 528,
      "sajda": false
    },
    {
      "number": 5939,
      "numberInSurah": 8,
      "text": "إِنَّهُۥ عَلَىٰ رَجْعِهِۦ لَقَادِرٌۭ",
      "translation": "Now, verily, He [who thus creates man in the first instance] is well able to bring him back [to life]",
      "juz": 30,
      "page": 591,
      "ruku": 528,
      "sajda": false
    },
    {
      "number": 5940,
      "numberInSurah": 9,
      "text": "يَوْمَ تُبْلَى ٱلسَّرَآئِرُ",
      "translation": "on the Day when all secrets will be laid bare,",
      "juz": 30,
      "page": 591,
      "ruku": 528,
      "sajda": false
    },
    {
      "number": 5941,
      "numberInSurah": 10,
      "text": "فَمَا لَهُۥ مِن قُوَّةٍۢ وَلَا نَاصِرٍۢ",
      "translation": "and [man] will have neither strength nor helper!",
      "juz": 30,
      "page": 591,
      "ruku": 528,
      "sajda": false
    },
    {
      "number": 5942,
      "numberInSurah": 11,
      "text": "وَٱلسَّمَآءِ ذَاتِ ٱلرَّجْعِ",
      "translation": "Consider the heavens, ever-revolving,",
      "juz": 30,
      "page": 591,
      "ruku": 528,
      "sajda": false
    },
    {
      "number": 5943,
      "numberInSurah": 12,
      "text": "وَٱلْأَرْضِ ذَاتِ ٱلصَّدْعِ",
      "translation": "and the earth, bursting forth with plants!",
      "juz": 30,
      "page": 591,
      "ruku": 528,
      "sajda": false
    },
    {
      "number": 5944,
      "numberInSurah": 13,
      "text": "إِنَّهُۥ لَقَوْلٌۭ فَصْلٌۭ",
      "translation": "BEHOLD, this [divine writ] is indeed a word that between truth and falsehood,",
      "juz": 30,
      "page": 591,
      "ruku": 528,
      "sajda": false
    },
    {
      "number": 5945,
      "numberInSurah": 14,
      "text": "وَمَا هُوَ بِٱلْهَزْلِ",
      "translation": "and is no idle tale.",
      "juz": 30,
      "page": 591,
      "ruku": 528,
      "sajda": false
    },
    {
      "number": 5946,
      "numberInSurah": 15,
      "text": "إِنَّهُمْ يَكِيدُونَ كَيْدًۭا",
      "translation": "Behold, they [who refuse to accept it] devise many a false argument [to disprove its truth];",
      "juz": 30,
      "page": 591,
      "ruku": 528,
      "sajda": false
    },
    {
      "number": 5947,
      "numberInSurah": 16,
      "text": "وَأَكِيدُ كَيْدًۭا",
      "translation": "but I shall bring all their scheming to nought.",
      "juz": 30,
      "page": 591,
      "ruku": 528,
      "sajda": false
    },
    {
      "number": 5948,
      "numberInSurah": 17,
      "text": "فَمَهِّلِ ٱلْكَٰفِرِينَ أَمْهِلْهُمْ رُوَيْدًۢا",
      "translation": "Let, then, the deniers of the truth have their will: let them have their will for a little while.",
      "juz": 30,
      "page": 591,
      "ruku": 528,
      "sajda": false
    }
  ]
}