{
  "number": 104,
  "name": "سُورَةُ الهُمَزَةِ",
  "englishName": "Al-Humaza",
  "englishNameTranslation": "The Traducer",
  "revelationType": "Meccan",
  "numberOfAyahs": 9,
  "ayahs": [
    {
      "number": 6180,
      "numberInSurah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَيْلٌۭ لِّكُلِّ هُمَزَةٍۢ لُّمَزَةٍ",
      "translation": "WOE unto every slanderer, fault-finder!",
      "juz": 30,
      "page": 601,
      "ruku": 546,
      "sajda": false
    },
    {
      "number": 6181,
      "numberInSurah": 2,
      "text": "ٱلَّذِى جَمَعَ مَالًۭا وَعَدَّدَهُۥ",
      "translation": "[Woe unto him who amasses wealth and counts it a safeguard,",
      "juz": 30,
      "page": 601,
      "ruku": 546,
      "sajda": false
    },
    {
      "number": 6182,
      "numberInSurah": 3,
      "text": "يَحْسَبُ أَنَّ مَالَهُۥٓ أَخْلَدَهُۥ",
      "translation": "thinking that his wealth will make him live forever!",
      "juz": 30,
      "page": 601,
      "ruku": 546,
      "sajda": false
    },
    {
      "number": 6183,
      "numberInSurah": 4,
      "text": "كَلَّا ۖ لَيُنۢبَذَنَّ فِى ٱلْحُطَمَةِ",
      "translation": "Nay, but [in the life to come such as] he shall indeed be abandoned to crushing torment!",
      "juz": 30,
      "page": 601,
      "ruku": 546,
      "sajda": false
    },
    {
      "number": 6184,
      "numberInSurah": 5,
      "text": "وَمَآ أَدْرَىٰكَ مَا ٱلْحُطَمَةُ",
      "translation": "And what could make thee conceive what that crushing torment will be?",
      "juz": 30,
      "page": 601,
      "ruku": 546,
      "sajda": false
    },
    {
      "number": 6185,
      "numberInSurah": 6,
      "text": "نَارُ ٱللَّهِ ٱلْمُوقَدَةُ",
      "translation": "A fire kindled by God,",
      "juz": 30,
      "page": 601,
      "ruku": 546,
      "sajda": false
    },
    {
      "number": 6186,
      "numberInSurah": 7,
      "text": "ٱلَّتِى تَطَّلِعُ عَلَى ٱلْأَفْـِٔدَةِ",
      "translation": "which will rise over the [guilty] hearts:",
      "juz": 30,
      "page": 601,
      "ruku": 546,
      "sajda": false
    },
    {
      "number": 6187,
      "numberInSurah": 8,
      "text": "إِنَّهَا عَلَيْهِم مُّؤْصَدَةٌۭ",
      "translation": "verily, it will close in upon them",
      "juz": 30,
      "page": 601,
      "ruku": 546,
      "sajda": false
    },
    {
      "number": 6188,
      "numberInSurah": 9,
      "text": "فِى عَمَدٍۢ مُّمَدَّدَةٍۭ",
      "translation": "in endless columns!",
      "juz": 30,
      "page": 601,
      "ruku": 546,
      "sajda": false
    }
  ]
}