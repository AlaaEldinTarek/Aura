{
  "number": 100,
  "name": "سُورَةُ العَادِيَاتِ",
  "englishName": "Al-Aadiyaat",
  "englishNameTranslation": "The Chargers",
  "revelationType": "Meccan",
  "numberOfAyahs": 11,
  "ayahs": [
    {
      "number": 6147,
      "numberInSurah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلْعَٰدِيَٰتِ ضَبْحًۭا",
      "translation": "Oh, the chargers that run panting,",
      "juz": 30,
      "page": 599,
      "ruku": 542,
      "sajda": false
    },
    {
      "number": 6148,
      "numberInSurah": 2,
      "text": "فَٱلْمُورِيَٰتِ قَدْحًۭا",
      "translation": "sparks of fire striking,",
      "juz": 30,
      "page": 599,
      "ruku": 542,
      "sajda": false
    },
    {
      "number": 6149,
      "numberInSurah": 3,
      "text": "فَٱلْمُغِيرَٰتِ صُبْحًۭا",
      "translation": "rushing to assault at morn,",
      "juz": 30,
      "page": 599,
      "ruku": 542,
      "sajda": false
    },
    {
      "number": 6150,
      "numberInSurah": 4,
      "text": "فَأَثَرْنَ بِهِۦ نَقْعًۭا",
      "translation": "thereby raising clouds of dust,",
      "juz": 30,
      "page": 599,
      "ruku": 542,
      "sajda": false
    },
    {
      "number": 6151,
      "numberInSurah": 5,
      "text": "فَوَسَطْنَ بِهِۦ جَمْعًا",
      "translation": "thereby storming [blindly] into any host!",
      "juz": 30,
      "page": 599,
      "ruku": 542,
      "sajda": false
    },
    {
      "number": 6152,
      "numberInSurah": 6,
      "text": "إِنَّ ٱلْإِنسَٰنَ لِرَبِّهِۦ لَكَنُودٌۭ",
      "translation": "VERILY, towards his Sustainer man is most ungrateful",
      "juz": 30,
      "page": 599,
      "ruku": 542,
      "sajda": false
    },
    {
      "number": 6153,
      "numberInSurah": 7,
      "text": "وَإِنَّهُۥ عَلَىٰ ذَٰلِكَ لَشَهِيدٌۭ",
      "translation": "and to this, behold, he [himself] bears witness indeed:",
      "juz": 30,
      "page": 599,
      "ruku": 542,
      "sajda": false
    },
    {
      "number": 6154,
      "numberInSurah": 8,
      "text": "وَإِنَّهُۥ لِحُبِّ ٱلْخَيْرِ لَشَدِيدٌ",
      "translation": "for, verily, to the love of wealth is he most ardently devoted.",
      "juz": 30,
      "page": 599,
      "ruku": 542,
      "sajda": false
    },
    {
      "number": 6155,
      "numberInSurah": 9,
      "text": "۞ أَفَلَا يَعْلَمُ إِذَا بُعْثِرَ مَا فِى ٱلْقُبُورِ",
      "translation": "But does he not know that [on the Last Day,] when all that is in the graves is raised and brought out,",
      "juz": 30,
      "page": 599,
      "ruku": 542,
      "sajda": false
    },
    {
      "number": 6156,
      "numberInSurah": 10,
      "text": "وَحُصِّلَ مَا فِى ٱلصُّدُورِ",
      "translation": "and all that is [hidden] in men's hearts is bared",
      "juz": 30,
      "page": 600,
      "ruku": 542,
      "sajda": false
    },
    {
      "number": 6157,
      "numberInSurah": 11,
      "text": "إِنَّ رَبَّهُم بِهِمْ يَوْمَئِذٍۢ لَّخَبِيرٌۢ",
      "translation": "that on that Day their Sustainer [will show that He] has always been fully aware of them?",
      "juz": 30,
      "page": 600,
      "ruku": 542,
      "sajda": false
    }
  ]
}