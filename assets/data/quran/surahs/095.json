      "sajda": false
    },
    {
      "number": 6100,
      "numberInSurah": 2,
      "text": "وَطُورِ سِينِينَ",
      "translation": "and Mount Sinai,",
      "juz": 30,
      "page": 597,
      "ruku": 537,
      "sajda": false
    },
    {
      "number": 6101,
      "numberInSurah": 3,
      "text": "وَهَٰذَا ٱلْبَلَدِ ٱلْأَمِينِ",
      "translation": "and this land secure!",
      "juz": 30,
      "page": 597,
      "ruku": 537,
      "sajda": false
    },
    {
      "number": 6102,
      "numberInSurah": 4,
      "text": "لَقَدْ خَلَقْنَا ٱلْإِنسَٰنَ فِىٓ أَحْسَنِ تَقْوِيمٍۢ",
      "translation": "Verily, We create man in the best conformation;",
      "juz": 30,
      "page": 597,
      "ruku": 537,
      "sajda": false
    },
    {
      "number": 6103,
      "numberInSurah": 5,
      "text": "ثُمَّ رَدَدْنَٰهُ أَسْفَلَ سَٰفِلِينَ",
      "translation": "and thereafter We reduce him to the lowest of low",
      "juz": 30,
      "page": 597,
      "ruku": 537,
      "sajda": false
    },
    {
      "number": 6104,
      "numberInSurah": 6,
      "text": "إِلَّا ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ فَلَهُمْ أَجْرٌ غَيْرُ مَمْنُونٍۢ",
      "translation": "excepting only such as attain to faith and do good works: and theirs shall be a reward unending!",
      "juz": 30,
      "page": 597,
      "ruku": 537,
      "sajda": false
    },
    {
      "number": 6105,
      "numberInSurah": 7,
      "text": "فَمَا يُكَذِّبُكَ بَعْدُ بِٱلدِّينِ",
      "translation": "What, then, [O man,] could henceforth cause thee to give the lie to this moral law?",
      "juz": 30,
      "page": 597,
      "ruku": 537,
      "sajda": false
    },
    {
      "number": 6106,
      "numberInSurah": 8,
      "text": "أَلَيْسَ ٱللَّهُ بِأَحْكَمِ ٱلْحَٰكِمِينَ",
      "translation": "Is not God the most just of judges?",
      "juz": 30,
      "page": 597,
      "ruku": 537,
      "sajda": false
    }
  ]
