      "sajda": false
    },
    {
      "number": 6108,
      "numberInSurah": 2,
      "text": "خَلَقَ ٱلْإِنسَٰنَ مِنْ عَلَقٍ",
      "translation": "created man out of a germ-cell",
      "juz": 30,
      "page": 597,
      "ruku": 538,
      "sajda": false
    },
    {
      "number": 6109,
      "numberInSurah": 3,
      "text": "ٱقْرَأْ وَرَبُّكَ ٱلْأَكْرَمُ",
      "translation": "Read - for thy Sustainer is the Most Bountiful One",
      "juz": 30,
      "page": 597,
      "ruku": 538,
      "sajda": false
    },
    {
      "number": 6110,
      "numberInSurah": 4,
      "text": "ٱلَّذِى عَلَّمَ بِٱلْقَلَمِ",
      "translation": "who has taught [man] the use of the pen –",
      "juz": 30,
      "page": 597,
      "ruku": 538,
      "sajda": false
    },
    {
      "number": 6111,
      "numberInSurah": 5,
      "text": "عَلَّمَ ٱلْإِنسَٰنَ مَا لَمْ يَعْلَمْ",
      "translation": "taught man what he did not know!",
      "juz": 30,
      "page": 597,
      "ruku": 538,
      "sajda": false
    },
    {
      "number": 6112,
      "numberInSurah": 6,
      "text": "كَلَّآ إِنَّ ٱلْإِنسَٰنَ لَيَطْغَىٰٓ",
      "translation": "Nay, verily, man becomes grossly overweening",
      "juz": 30,
      "page": 597,
      "ruku": 538,
      "sajda": false
    },
    {
      "number": 6113,
      "numberInSurah": 7,
      "text": "أَن رَّءَاهُ ٱسْتَغْنَىٰٓ",
      "translation": "whenever he believes himself to be self-sufficient:",
      "juz": 30,
      "page": 597,
      "ruku": 538,
      "sajda": false
    },
    {
      "number": 6114,
      "numberInSurah": 8,
      "text": "إِنَّ إِلَىٰ رَبِّكَ ٱلرُّجْعَىٰٓ",
      "translation": "for, behold, unto thy Sustainer all must return.",
      "juz": 30,
      "page": 597,
      "ruku": 538,
      "sajda": false
    },
    {
      "number": 6115,
      "numberInSurah": 9,
      "text": "أَرَءَيْتَ ٱلَّذِى يَنْهَىٰ",
      "translation": "HAST THOU ever considered him who tries to prevent",
      "juz": 30,
      "page": 597,
      "ruku": 538,
      "sajda": false
    },
    {
      "number": 6116,
      "numberInSurah": 10,
      "text": "عَبْدًا إِذَا صَلَّىٰٓ",
      "translation": "a servant [of God] from praying?",
      "juz": 30,
      "page": 597,
      "ruku": 538,
      "sajda": false
    },
    {
      "number": 6117,
      "numberInSurah": 11,
      "text": "أَرَءَيْتَ إِن كَانَ عَلَى ٱلْهُدَىٰٓ",
      "translation": "Hast thou considered whether he is on the right way,",
      "juz": 30,
      "page": 597,
      "ruku": 538,
      "sajda": false
    },
    {
      "number": 6118,
      "numberInSurah": 12,
      "text": "أَوْ أَمَرَ بِٱلتَّقْوَىٰٓ",
      "translation": "or is concerned with God-consciousness?",
      "juz": 30,
      "page": 597,
      "ruku": 538,
      "sajda": false
    },
    {
      "number": 6119,
      "numberInSurah": 13,
      "text": "أَرَءَيْتَ إِن كَذَّبَ وَتَوَلَّىٰٓ",
      "translation": "Hast thou considered whether he may [not] be giving the lie to the truth and turning his back [upon it]?",
      "juz": 30,
      "page": 597,
      "ruku": 538,
      "sajda": false
    },
    {
      "number": 6120,
      "numberInSurah": 14,
      "text": "أَلَمْ يَعْلَم بِأَنَّ ٱللَّهَ يَرَىٰ",
      "translation": "Does he, then, not know that God sees [all]?",
      "juz": 30,
      "page": 597,
      "ruku": 538,
      "sajda": false
    },
    {
      "number": 6121,
      "numberInSurah": 15,
      "text": "كَلَّا لَئِن لَّمْ يَنتَهِ لَنَسْفَعًۢا بِٱلنَّاصِيَةِ",
      "translation": "Nay, if he desist not, We shall most surely drag him down upon his forehead",
      "juz": 30,
      "page": 597,
      "ruku": 538,
      "sajda": false
    },
    {
      "number": 6122,
      "numberInSurah": 16,
      "text": "نَاصِيَةٍۢ كَٰذِبَةٍ خَاطِئَةٍۢ",
      "translation": "the lying, rebellious forehead! –",
      "juz": 30,
      "page": 597,
      "ruku": 538,
      "sajda": false
    },
    {
      "number": 6123,
      "numberInSurah": 17,
      "text": "فَلْيَدْعُ نَادِيَهُۥ",
      "translation": "and then let him summon [to his aid] the counsels of his own [spurious] wisdom,",
      "juz": 30,
      "page": 597,
      "ruku": 538,
      "sajda": false
    },
    {
      "number": 6124,
      "numberInSurah": 18,
      "text": "سَنَدْعُ ٱلزَّبَانِيَةَ",
      "translation": "[the while] We shall summon the forces of heavenly chastisement!",
      "juz": 30,
      "page": 597,
      "ruku": 538,
      "sajda": false
    },
    {
      "number": 6125,
      "numberInSurah": 19,
      "text": "كَلَّا لَا تُطِعْهُ وَٱسْجُدْ وَٱقْتَرِب ۩",
      "translation": "Nay, pay thou no heed to him, but prostrate thyself [before God] and draw close [unto Him]!",
      "juz": 30,
