{
  "number": 80,
  "name": "سُورَةُ عَبَسَ",
  "englishName": "Abasa",
  "englishNameTranslation": "He frowned",
  "revelationType": "Meccan",
  "numberOfAyahs": 42,
  "ayahs": [
    {
      "number": 5759,
      "numberInSurah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ عَبَسَ وَتَوَلَّىٰٓ",
      "translation": "HE FROWNED and turned away",
      "juz": 30,
      "page": 585,
      "ruku": 522,
      "sajda": false
    },
    {
      "number": 5760,
      "numberInSurah": 2,
      "text": "أَن جَآءَهُ ٱلْأَعْمَىٰ",
      "translation": "because the blind man approached him!",
      "juz": 30,
      "page": 585,
      "ruku": 522,
      "sajda": false
    },
    {
      "number": 5761,
      "numberInSurah": 3,
      "text": "وَمَا يُدْرِيكَ لَعَلَّهُۥ يَزَّكَّىٰٓ",
      "translation": "Yet for all thou didst know, [O Muhammad,] he might perhaps have grown in purity,",
      "juz": 30,
      "page": 585,
      "ruku": 522,
      "sajda": false
    },
    {
      "number": 5762,
      "numberInSurah": 4,
      "text": "أَوْ يَذَّكَّرُ فَتَنفَعَهُ ٱلذِّكْرَىٰٓ",
      "translation": "or have been reminded [of the truth], and helped by this reminder.",
      "juz": 30,
      "page": 585,
      "ruku": 522,
      "sajda": false
    },
    {
      "number": 5763,
      "numberInSurah": 5,
      "text": "أَمَّا مَنِ ٱسْتَغْنَىٰ",
      "translation": "Now as for him who believes himself to be self-sufficient",
      "juz": 30,
      "page": 585,
      "ruku": 522,
      "sajda": false
    },
    {
      "number": 5764,
      "numberInSurah": 6,
      "text": "فَأَنتَ لَهُۥ تَصَدَّىٰ",
      "translation": "to him didst thou give thy whole attention,",
      "juz": 30,
      "page": 585,
      "ruku": 522,
      "sajda": false
    },
    {
      "number": 5765,
      "numberInSurah": 7,
      "text": "وَمَا عَلَيْكَ أَلَّا يَزَّكَّىٰ",
      "translation": "although thou art not accountable for his failure to attain to purity;",
      "juz": 30,
      "page": 585,
      "ruku": 522,
      "sajda": false
    },
    {
      "number": 5766,
      "numberInSurah": 8,
      "text": "وَأَمَّا مَن جَآءَكَ يَسْعَىٰ",
      "translation": "but as for him who came unto thee full of eagerness",
      "juz": 30,
      "page": 585,
      "ruku": 522,
      "sajda": false
    },
    {
      "number": 5767,
      "numberInSurah": 9,
      "text": "وَهُوَ يَخْشَىٰ",
      "translation": "and in awe [of God]",
      "juz": 30,
      "page": 585,
      "ruku": 522,
      "sajda": false
    },
    {
      "number": 5768,
      "numberInSurah": 10,
      "text": "فَأَنتَ عَنْهُ تَلَهَّىٰ",
      "translation": "him didst thou disregard!",
      "juz": 30,
      "page": 585,
      "ruku": 522,
      "sajda": false
    },
    {
      "number": 5769,
      "numberInSurah": 11,
      "text": "كَلَّآ إِنَّهَا تَذْكِرَةٌۭ",
      "translation": "NAY, VERILY, these [messages] are but a reminder:",
      "juz": 30,
      "page": 585,
      "ruku": 522,
      "sajda": false
    },
    {
      "number": 5770,
      "numberInSurah": 12,
      "text": "فَمَن شَآءَ ذَكَرَهُۥ",
      "translation": "and so, whoever is willing may remember Him",
      "juz": 30,
      "page": 585,
      "ruku": 522,
      "sajda": false
    },
    {
      "number": 5771,
      "numberInSurah": 13,
      "text": "فِى صُحُفٍۢ مُّكَرَّمَةٍۢ",
      "translation": "in [the light of His] revelations blest with dignity,",
      "juz": 30,
      "page": 585,
      "ruku": 522,
      "sajda": false
    },
    {
      "number": 5772,
      "numberInSurah": 14,
      "text": "مَّرْفُوعَةٍۢ مُّطَهَّرَةٍۭ",
      "translation": "lofty and pure,",
      "juz": 30,
      "page": 585,
      "ruku": 522,
      "sajda": false
    },
    {
      "number": 5773,
      "numberInSurah": 15,
      "text": "بِأَيْدِى سَفَرَةٍۢ",
      "translation": "[borne] by the hands of messengers",
      "juz": 30,
      "page": 585,
      "ruku": 522,
      "sajda": false
    },
    {
      "number": 5774,
      "numberInSurah": 16,
      "text": "كِرَامٍۭ بَرَرَةٍۢ",
      "translation": "noble and most virtuous.",
      "juz": 30,
      "page": 585,
      "ruku": 522,
      "sajda": false
    },
    {
      "number": 5775,
      "numberInSurah": 17,
      "text": "قُتِلَ ٱلْإِنسَٰنُ مَآ أَكْفَرَهُۥ",
      "translation": "[But only too often] man destroys himself: how stubbornly does he deny the truth!",
      "juz": 30,
      "page": 585,
      "ruku": 522,
      "sajda": false
    },
    {
      "number": 5776,
      "numberInSurah": 18,
      "text": "مِنْ أَىِّ شَىْءٍ خَلَقَهُۥ",
      "translation": "[Does man ever consider] out of what substance [God] creates him?",
      "juz": 30,
      "page": 585,
      "ruku": 522,
      "sajda": false
    },
    {
      "number": 5777,
      "numberInSurah": 19,
      "text": "مِن نُّطْفَةٍ خَلَقَهُۥ فَقَدَّرَهُۥ",
      "translation": "Out of a drop of sperm He creates him, and thereupon determines his nature,",
      "juz": 30,
      "page": 585,
      "ruku": 522,
      "sajda": false
    },
    {
      "number": 5778,
      "numberInSurah": 20,
      "text": "ثُمَّ ٱلسَّبِيلَ يَسَّرَهُۥ",
      "translation": "and then makes it easy for him to go through life;",
      "juz": 30,
      "page": 585,
      "ruku": 522,
      "sajda": false
    },
    {
      "number": 5779,
      "numberInSurah": 21,
      "text": "ثُمَّ أَمَاتَهُۥ فَأَقْبَرَهُۥ",
      "translation": "and in the end He causes him to die and brings him to the grave;",
      "juz": 30,
      "page": 585,
      "ruku": 522,
      "sajda": false
    },
    {
      "number": 5780,
      "numberInSurah": 22,
      "text": "ثُمَّ إِذَا شَآءَ أَنشَرَهُۥ",
      "translation": "and then, if it be His will, He shall raise him again to life,",
      "juz": 30,
      "page": 585,
      "ruku": 522,
      "sajda": false
    },
    {
      "number": 5781,
      "numberInSurah": 23,
      "text": "كَلَّا لَمَّا يَقْضِ مَآ أَمَرَهُۥ",
      "translation": "Nay, but [man] has never yet fulfilled what He has enjoined upon him!",
      "juz": 30,
      "page": 585,
      "ruku": 522,
      "sajda": false
    },
    {
      "number": 5782,
      "numberInSurah": 24,
      "text": "فَلْيَنظُرِ ٱلْإِنسَٰنُ إِلَىٰ طَعَامِهِۦٓ",
      "translation": "Let man, then, consider [the sources of] his food:",
      "juz": 30,
      "page": 585,
      "ruku": 522,
      "sajda": false
    },
    {
      "number": 5783,
      "numberInSurah": 25,
      "text": "أَنَّا صَبَبْنَا ٱلْمَآءَ صَبًّۭا",
      "translation": "[how it is] that We pour down water, pouring it down abundantly;",
      "juz": 30,
      "page": 585,
      "ruku": 522,
      "sajda": false
    },
    {
      "number": 5784,
      "numberInSurah": 26,
      "text": "ثُمَّ شَقَقْنَا ٱلْأَرْضَ شَقًّۭا",
      "translation": "and then We cleave the earth [with new growth], cleaving it asunder,",
      "juz": 30,
      "page": 585,
      "ruku": 522,
      "sajda": false
    },
    {
      "number": 5785,
      "numberInSurah": 27,
      "text": "فَأَنۢبَتْنَا فِيهَا حَبًّۭا",
      "translation": "and thereupon We cause grain to grow out of it,",
      "juz": 30,
      "page": 585,
      "ruku": 522,
      "sajda": false
    },
    {
      "number": 5786,
      "numberInSurah": 28,
      "text": "وَعِنَبًۭا وَقَضْبًۭا",
      "translation": "and vines and edible plants,",
      "juz": 30,
      "page": 585,
      "ruku": 522,
      "sajda": false
    },
    {
      "number": 5787,
      "numberInSurah": 29,
      "text": "وَزَيْتُونًۭا وَنَخْلًۭا",
      "translation": "and olive trees and date-palms,",
      "juz": 30,
      "page": 585,
      "ruku": 522,
      "sajda": false
    },
    {
      "number": 5788,
      "numberInSurah": 30,
      "text": "وَحَدَآئِقَ غُلْبًۭا",
      "translation": "and gardens dense with foliage,",
      "juz": 30,
      "page": 585,
      "ruku": 522,
      "sajda": false
    },
    {
      "number": 5789,
      "numberInSurah": 31,
      "text": "وَفَٰكِهَةًۭ وَأَبًّۭا",
      "translation": "and fruits and herbage,",
      "juz": 30,
      "page": 585,
      "ruku": 522,
      "sajda": false
    },
    {
      "number": 5790,
      "numberInSurah": 32,
      "text": "مَّتَٰعًۭا لَّكُمْ وَلِأَنْعَٰمِكُمْ",
      "translation": "for you and for your animals to enjoy.",
      "juz": 30,
      "page": 585,
      "ruku": 522,
      "sajda": false
    },
    {
      "number": 5791,
      "numberInSurah": 33,
      "text": "فَإِذَا جَآءَتِ ٱلصَّآخَّةُ",
      "translation": "AND SO, when the piercing call [of resurrection] is heard",
      "juz": 30,
      "page": 585,
      "ruku": 522,
      "sajda": false
    },
    {
      "number": 5792,
      "numberInSurah": 34,
      "text": "يَوْمَ يَفِرُّ ٱلْمَرْءُ مِنْ أَخِيهِ",
      "translation": "on a Day when everyone will [want to] flee from his brother,",
      "juz": 30,
      "page": 585,
      "ruku": 522,
      "sajda": false
    },
    {
      "number": 5793,
      "numberInSurah": 35,
      "text": "وَأُمِّهِۦ وَأَبِيهِ",
      "translation": "and from his mother and father,",
      "juz": 30,
      "page": 585,
      "ruku": 522,
      "sajda": false
    },
    {
      "number": 5794,
      "numberInSurah": 36,
      "text": "وَصَٰحِبَتِهِۦ وَبَنِيهِ",
      "translation": "and from his spouse and his children:",
      "juz": 30,
      "page": 585,
      "ruku": 522,
      "sajda": false
    },
    {
      "number": 5795,
      "numberInSurah": 37,
      "text": "لِكُلِّ ٱمْرِئٍۢ مِّنْهُمْ يَوْمَئِذٍۢ شَأْنٌۭ يُغْنِيهِ",
      "translation": "on that Day, to every one of them will his own state be of sufficient concern.",
      "juz": 30,
      "page": 585,
      "ruku": 522,
      "sajda": false
    },
    {
      "number": 5796,
      "numberInSurah": 38,
      "text": "وُجُوهٌۭ يَوْمَئِذٍۢ مُّسْفِرَةٌۭ",
      "translation": "Some faces will on that Day be bright with happiness,",
      "juz": 30,
      "page": 585,
      "ruku": 522,
      "sajda": false
    },
    {
      "number": 5797,
      "numberInSurah": 39,
      "text": "ضَاحِكَةٌۭ مُّسْتَبْشِرَةٌۭ",
      "translation": "laughing, rejoicing at glad tidings.",
      "juz": 30,
      "page": 585,
      "ruku": 522,
      "sajda": false
    },
    {
      "number": 5798,
      "numberInSurah": 40,
      "text": "وَوُجُوهٌۭ يَوْمَئِذٍ عَلَيْهَا غَبَرَةٌۭ",
      "translation": "And some faces will on that Day with dust be covered,",
      "juz": 30,
      "page": 585,
      "ruku": 522,
      "sajda": false
    },
    {
      "number": 5799,
      "numberInSurah": 41,
      "text": "تَرْهَقُهَا قَتَرَةٌ",
      "translation": "with darkness overspread:",
      "juz": 30,
      "page": 585,
      "ruku": 522,
      "sajda": false
    },
    {
      "number": 5800,
      "numberInSurah": 42,
      "text": "أُو۟لَٰٓئِكَ هُمُ ٱلْكَفَرَةُ ٱلْفَجَرَةُ",
      "translation": "these, these will be the ones who denied the truth and were immersed in iniquity!",
      "juz": 30,
      "page": 585,
      "ruku": 522,
      "sajda": false
    }
  ]
}