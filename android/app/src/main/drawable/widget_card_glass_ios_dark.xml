<?xml version="1.0" encoding="utf-8"?>
<!-- iOS-style Glassmorphism - Dark theme with 3D depth -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Outer shadow for 3D depth (elevation) -->
    <item android:left="2dp" android:top="3dp" android:right="2dp" android:bottom="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#40000000" />
            <corners android:radius="22dp" />
        </shape>
    </item>

    <!-- Main glass background with high transparency -->
    <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <!-- Very transparent dark - 35% opacity -->
            <solid android:color="#5C000000" />
            <corners android:radius="22dp" />
        </shape>
    </item>

    <!-- Inner highlight/shine for glass reflection -->
    <item android:left="3dp" android:top="3dp" android:right="3dp" android:bottom="5dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#25FFFFFF"
                android:centerColor="#00FFFFFF"
                android:endColor="#00FFFFFF"
                android:type="linear" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <!-- Glass border effect -->
    <item android:left="3dp" android:top="3dp" android:right="3dp" android:bottom="5dp">
        <shape android:shape="rectangle">
            <stroke
                android:width="1dp"
                android:color="#40FFFFFF" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <!-- Subtle inner glow -->
    <item android:left="4dp" android:top="4dp" android:right="4dp" android:bottom="6dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#15FFFFFF"
                android:endColor="#00FFFFFF"
                android:type="linear" />
            <corners android:radius="19dp" />
        </shape>
    </item>

</layer-list>
