<?xml version="1.0" encoding="utf-8"?>
<!-- Glass/Frosted effect for dark theme - like iOS blur -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Semi-transparent dark background for glass effect -->
    <solid android:color="#D9282828" />

    <!-- Subtle stroke for glass edge effect -->
    <stroke
        android:width="1dp"
        android:color="#33FFFFFF" />

    <!-- Rounded corners -->
    <corners android:radius="20dp" />

    <!-- Subtle padding for depth -->
    <padding
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp" />
</shape>
