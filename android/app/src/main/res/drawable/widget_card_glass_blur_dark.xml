<?xml version="1.0" encoding="utf-8"?>
<!-- Advanced Glass effect with gradient for dark theme -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base blur simulation gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#F0303030"
                android:centerColor="#E6282828"
                android:endColor="#DD202020"
                android:type="linear" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <!-- Glass shine overlay -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#15FFFFFF" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <!-- Subtle border -->
    <item>
        <shape android:shape="rectangle">
            <stroke
                android:width="1.5dp"
                android:color="#25FFFFFF" />
            <corners android:radius="20dp" />
        </shape>
    </item>

</layer-list>
