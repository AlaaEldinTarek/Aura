<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Small tight card background around logo -->
    <item
        android:left="26dp"
        android:top="26dp"
        android:right="26dp"
        android:bottom="26dp">
        <shape android:shape="rectangle">
            <solid android:color="#F0F4FF" />
            <corners android:radius="14dp" />
        </shape>
    </item>

    <!-- Blue border -->
    <item
        android:left="26dp"
        android:top="26dp"
        android:right="26dp"
        android:bottom="26dp">
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <stroke android:width="1dp" android:color="#CCE0FF" />
            <corners android:radius="14dp" />
        </shape>
    </item>

    <!-- Logo — same size, just 6dp inside the card -->
    <item
        android:left="32dp"
        android:top="32dp"
        android:right="32dp"
        android:bottom="32dp"
        android:drawable="@mipmap/ic_launcher" />

</layer-list>
