<?xml version="1.0" encoding="utf-8"?>
<!-- iOS-style Glassmorphism - Light theme with 3D depth -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Outer shadow for 3D depth (elevation) -->
    <item android:left="2dp" android:top="3dp" android:right="2dp" android:bottom="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#20000000" />
            <corners android:radius="7dp" />
        </shape>
    </item>

    <!-- Main glass background with high transparency -->
    <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <!-- Semi-transparent white - 40% opacity -->
            <solid android:color="#66FFFFFF" />
            <corners android:radius="7dp" />
        </shape>
    </item>

    <!-- Inner highlight/shine for glass reflection -->
    <item android:left="3dp" android:top="3dp" android:right="3dp" android:bottom="5dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#30FFFFFF"
                android:centerColor="#00FFFFFF"
                android:endColor="#00FFFFFF"
                android:type="linear" />
            <corners android:radius="7dp" />
        </shape>
    </item>

    <!-- Subtle inner glow -->
    <item android:left="4dp" android:top="4dp" android:right="4dp" android:bottom="6dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#15FFFFFF"
                android:endColor="#00FFFFFF"
                android:type="linear" />
            <corners android:radius="7dp" />
        </shape>
    </item>

</layer-list>
