<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="100"
    android:viewportHeight="100">

    <!-- Sun rays -->
    <group
        android:strokeWidth="2"
        android:strokeColor="#ff9900"
        android:strokeAlpha="0.8">
        <path
            android:strokeLineCap="round"
            android:pathData="M50,25 L50,35"/>
        <path
            android:strokeLineCap="round"
            android:pathData="M70,30 L65,35"/>
        <path
            android:strokeLineCap="round"
            android:pathData="M30,30 L35,35"/>
        <path
            android:strokeLineCap="round"
            android:pathData="M75,50 L65,50"/>
        <path
            android:strokeLineCap="round"
            android:pathData="M25,50 L35,50"/>
    </group>

    <!-- Rising sun -->
    <path
        android:fillColor="#ff9900"
        android:pathData="M50,60m-18,0a18,18 0,1 1,36 0a18,18 0,1 1,-36 0"/>

    <!-- Sun highlight for 3D effect -->
    <path
        android:fillColor="#ffffff"
        android:fillAlpha="0.4"
        android:pathData="M45,55m-8,0a8,6 0,1 1,16 0a8,6 0,1 1,-16 0"/>

    <!-- Horizon line -->
    <path
        android:strokeColor="#8b4513"
        android:strokeWidth="2"
        android:pathData="M0,78 L100,78"/>
</vector>
