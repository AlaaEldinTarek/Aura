<?xml version="1.0" encoding="utf-8"?>
<!-- Custom notification layout with BIG logo -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="20dp"
    android:background="#F5F5F5">

    <!-- BIG Logo - 80dp (HUGE!) -->
    <ImageView
        android:id="@+id/notification_logo"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@mipmap/ic_launcher"
        android:scaleType="centerCrop"
        android:contentDescription="Aura Logo" />

    <!-- Text Content -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="16dp"
        android:orientation="vertical">

        <!-- Prayer Name -->
        <TextView
            android:id="@+id/notification_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Maghrib"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@android:color/black" />

        <!-- Countdown -->
        <TextView
            android:id="@+id/notification_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏰ 2h 15m 30s"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#007DFF" />

        <!-- Until text -->
        <TextView
            android:id="@+id/notification_until"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="until adhan"
            android:textSize="16sp"
            android:textColor="@android:color/darker_gray" />

    </LinearLayout>

</LinearLayout>
