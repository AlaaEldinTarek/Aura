<?xml version="1.0" encoding="utf-8"?>
<!-- Combined Prayer Widget — Light RTL (4x3) with ViewFlipper -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:layoutDirection="rtl"
    android:background="@drawable/widget_v3_bg_light"
    android:paddingStart="14dp"
    android:paddingEnd="14dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <!-- Tab Bar -->
    <LinearLayout
        android:id="@+id/tab_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView
            android:id="@+id/tab_next_prayer"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:text="الصلاة القادمة"
            android:textSize="10sp"
            android:textColor="#B5821B"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold"
            android:letterSpacing="0.06"
            android:gravity="center"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:background="@drawable/widget_tab_active_light"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/tab_timeline"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:text="الجدول"
            android:textSize="10sp"
            android:textColor="#9A8F78"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold"
            android:letterSpacing="0.06"
            android:gravity="center"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/widget_tab_inactive_light"
            android:clickable="true"
            android:focusable="true" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/widget_location_small"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="الرياض"
                android:textSize="8sp"
                android:textColor="#7A6E5A"
                android:layout_marginEnd="3dp" />

            <ImageView
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:src="@drawable/widget_location_pin"
                android:scaleType="fitCenter" />
        </LinearLayout>
    </LinearLayout>

    <!-- ViewFlipper: Next Prayer (0) and Timeline (1) -->
    <ViewFlipper
        android:id="@+id/view_flipper"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- ═══ View 0: Next Prayer (same as NextPrayerWidget) ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Left: prayer info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.4"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/widget_next_prayer_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="العصر"
                        android:textSize="34sp"
                        android:textColor="#2A2418"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/widget_next_prayer_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="٠٣:٢٥"
                        android:textSize="20sp"
                        android:textColor="#B5821B"
                        android:fontFamily="monospace"
                    android:textDirection="ltr"
                        android:layout_marginStart="10dp" />

                    <TextView
                        android:id="@+id/widget_next_prayer_ampm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="مساءً"
                        android:textSize="15sp"
                        android:textColor="#7A6E5A"
                        android:layout_marginStart="3dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="6dp"
                    android:background="@drawable/widget_v3_pill_light"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:minHeight="28dp">

                    <ImageView
                        android:id="@+id/widget_progress_bar"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:scaleType="fitCenter" />

                    <Chronometer
                        android:id="@+id/widget_time_remaining"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:textColor="#8A6110"
                        android:fontFamily="monospace"
                        android:countDown="true"
                        android:textDirection="ltr"
                        android:layout_marginStart="8dp" />

                    <TextView
                        android:id="@+id/widget_time_remaining_seconds"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="حتى موعد الأذان"
                        android:textSize="8sp"
                        android:textColor="#7A6E5A"
                        android:fontFamily="monospace"
                        android:layout_marginStart="4dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Right: date card -->
            <LinearLayout
                android:layout_width="140dp"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:background="@drawable/widget_v3_panel_light"
                android:padding="10dp"
                android:layout_marginStart="10dp">

                <TextView
                    android:id="@+id/widget_day_of_week"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="الثلاثاء"
                    android:textSize="10sp"
                    android:textColor="#B5821B"
                    android:fontFamily="sans-serif-medium"
                    android:textStyle="bold"
                    android:gravity="center" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:layout_marginTop="2dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/widget_hijri_label"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="الهجري"
                            android:textSize="6sp"
                            android:textColor="#9A8F78"
                            android:fontFamily="monospace"
                            android:letterSpacing="0.12"
                            android:gravity="center" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/widget_hijri_day"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="٤"
                                android:textSize="14sp"
                                android:textColor="#2A2418"
                                android:fontFamily="sans-serif-medium"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/widget_hijri_month"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ذو القعدة"
                                android:layout_marginStart="4dp"
                                android:textSize="14sp"
                                android:textColor="#B5821B"
                                android:fontFamily="sans-serif-medium"
                                android:textStyle="bold"
                                android:maxLines="1"
                                android:ellipsize="end" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/widget_hijri_year"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="١٤٤٧ هـ"
                            android:textSize="8sp"
                            android:textColor="#9A8F78"
                            android:fontFamily="monospace"
                            android:gravity="center" />
                    </LinearLayout>

                    <FrameLayout
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="3dp"
                        android:layout_marginEnd="3dp"
                        android:background="#1A3C2D14" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/widget_gregorian_label"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="الميلادي"
                            android:textSize="6sp"
                            android:textColor="#9A8F78"
                            android:fontFamily="monospace"
                            android:letterSpacing="0.12"
                            android:gravity="center" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/widget_gregorian_day"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="٢١"
                                android:textSize="14sp"
                                android:textColor="#2A2418"
                                android:fontFamily="sans-serif-medium"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/widget_gregorian_month"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="أبريل"
                                android:textSize="14sp"
                                android:textColor="#B5821B"
                                android:fontFamily="sans-serif-medium"
                                android:textStyle="bold"
                                android:layout_marginStart="4dp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/widget_gregorian_year"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="٢٠٢٦"
                            android:textSize="8sp"
                            android:textColor="#9A8F78"
                            android:fontFamily="monospace"
                            android:gravity="center" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ═══ View 1: Day Timeline (LTR for chronological order) ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:layoutDirection="ltr">

            <!-- Top section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layoutDirection="rtl">

                <!-- Right in RTL: Current prayer -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/timeline_current_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="الظهر"
                        android:textSize="28sp"
                        android:textColor="#2A2418"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="2dp">

                        <TextView
                            android:id="@+id/timeline_current_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="١١:٥٢"
                            android:textSize="16sp"
                            android:textColor="#B5821B"
                            android:fontFamily="monospace"
                            android:textDirection="ltr" />

                        <TextView
                            android:id="@+id/timeline_current_ampm"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="صباحاً"
                            android:textSize="12sp"
                            android:textColor="#7A6E5A"
                            android:layout_marginStart="2dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Left in RTL: Countdown -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="start">

                    <TextView
                        android:id="@+id/timeline_next_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="التالي · العصر بعد"
                        android:textSize="8sp"
                        android:textColor="#7A6E5A"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:id="@+id/timeline_countdown_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="١ س ٠٢ د"
                        android:textSize="22sp"
                        android:textColor="#B5821B"
                        android:fontFamily="sans-serif-medium"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp" />

                    <TextView
                        android:id="@+id/timeline_secondary_info"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="الثلاثاء ٢١ أبريل"
                        android:textSize="7sp"
                        android:textColor="#9A8F78"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.06"
                        android:layout_marginTop="1dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Timeline: bar through dots -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp">

                <ImageView
                    android:id="@+id/timeline_progress_bar"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:layout_gravity="top"
                    android:layout_marginTop="4dp"
                    android:scaleType="fitXY" />

            <!-- 6 prayer dots row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layoutDirection="ltr">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">
                    <ImageView android:id="@+id/timeline_dot_0" android:layout_width="12dp" android:layout_height="12dp" android:scaleType="fitCenter" />
                    <TextView android:id="@+id/timeline_name_0" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="الفجر" android:textSize="8sp" android:textColor="#9A8F78" android:maxLines="1" android:layout_marginTop="3dp" />
                    <TextView android:id="@+id/timeline_time_0" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="٠٤:٢١" android:textSize="7sp" android:textColor="#9A8F78" android:fontFamily="monospace" android:textDirection="ltr" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">
                    <ImageView android:id="@+id/timeline_dot_1" android:layout_width="12dp" android:layout_height="12dp" android:scaleType="fitCenter" />
                    <TextView android:id="@+id/timeline_name_1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="الشروق" android:textSize="8sp" android:textColor="#9A8F78" android:maxLines="1" android:layout_marginTop="3dp" />
                    <TextView android:id="@+id/timeline_time_1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="٠٥:٤٧" android:textSize="7sp" android:textColor="#9A8F78" android:fontFamily="monospace" android:textDirection="ltr" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">
                    <ImageView android:id="@+id/timeline_dot_2" android:layout_width="12dp" android:layout_height="12dp" android:scaleType="fitCenter" />
                    <TextView android:id="@+id/timeline_name_2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="الظهر" android:textSize="8sp" android:textColor="#2A2418" android:textStyle="bold" android:maxLines="1" android:layout_marginTop="3dp" />
                    <TextView android:id="@+id/timeline_time_2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="١١:٥٢" android:textSize="7sp" android:textColor="#2A2418" android:fontFamily="monospace" android:textDirection="ltr" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">
                    <ImageView android:id="@+id/timeline_dot_3" android:layout_width="12dp" android:layout_height="12dp" android:scaleType="fitCenter" />
                    <TextView android:id="@+id/timeline_name_3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="العصر" android:textSize="8sp" android:textColor="#8A6110" android:textStyle="bold" android:maxLines="1" android:layout_marginTop="3dp" />
                    <TextView android:id="@+id/timeline_time_3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="١٥:١٤" android:textSize="7sp" android:textColor="#8A6110" android:fontFamily="monospace" android:textDirection="ltr" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">
                    <ImageView android:id="@+id/timeline_dot_4" android:layout_width="12dp" android:layout_height="12dp" android:scaleType="fitCenter" />
                    <TextView android:id="@+id/timeline_name_4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="المغرب" android:textSize="8sp" android:textColor="#9A8F78" android:maxLines="1" android:layout_marginTop="3dp" />
                    <TextView android:id="@+id/timeline_time_4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="١٨:٢٩" android:textSize="7sp" android:textColor="#9A8F78" android:fontFamily="monospace" android:textDirection="ltr" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">
                    <ImageView android:id="@+id/timeline_dot_5" android:layout_width="12dp" android:layout_height="12dp" android:scaleType="fitCenter" />
                    <TextView android:id="@+id/timeline_name_5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="العشاء" android:textSize="8sp" android:textColor="#9A8F78" android:maxLines="1" android:layout_marginTop="3dp" />
                    <TextView android:id="@+id/timeline_time_5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="١٩:٥٢" android:textSize="7sp" android:textColor="#9A8F78" android:fontFamily="monospace" android:textDirection="ltr" />
                </LinearLayout>
            </LinearLayout>
            </FrameLayout>
        </LinearLayout>
    </ViewFlipper>
</LinearLayout>
