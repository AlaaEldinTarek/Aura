<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/daily_widget_bg_dark"
    android:padding="10dp">

    <!-- Top row: icon + label + source -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/widget_type_emoji"
            android:text="📖"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/widget_type_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="Verse of the Day"
            android:textSize="9sp"
            android:textColor="#F5B301"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/widget_source"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="94:6"
            android:textSize="9sp"
            android:textColor="#F5B301"
            android:fontFamily="sans-serif"
            android:background="@drawable/daily_widget_source_bg_dark"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="1dp"
            android:paddingBottom="1dp" />

    </LinearLayout>

    <!-- Amber divider -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F5B301"
        android:alpha="0.3"
        android:layout_marginBottom="6dp" />

    <!-- Arabic text -->
    <TextView
        android:id="@+id/widget_arabic"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="إِنَّ مَعَ الْعُسْرِ يُسْرًا"
        android:textSize="14sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:fontFamily="sans-serif"
        android:gravity="center"
        android:textDirection="rtl"
        android:maxLines="3"
        android:ellipsize="end"
        android:lineSpacingMultiplier="1.3" />

    <!-- Amber divider dot -->
    <FrameLayout
        android:layout_width="40dp"
        android:layout_height="2dp"
        android:background="#F5B301"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="5dp"
        android:layout_marginBottom="5dp" />

    <!-- Translation -->
    <TextView
        android:id="@+id/widget_translation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Indeed, with hardship comes ease."
        android:textSize="10sp"
        android:textColor="#B0B0B0"
        android:fontFamily="sans-serif"
        android:gravity="center"
        android:maxLines="2"
        android:ellipsize="end"
        android:lineSpacingMultiplier="1.3"
        android:textStyle="italic" />

</LinearLayout>
