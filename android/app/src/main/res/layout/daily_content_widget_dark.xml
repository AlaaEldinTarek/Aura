<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@drawable/widget_task_background_dark"
    android:padding="3dp">

    <!-- Left: Content (75%) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="3"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingEnd="8dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_type_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📖 Verse of the Day"
            android:textSize="10sp"
            android:textColor="#888888"
            android:fontFamily="sans-serif"
            android:gravity="center" />

        <TextView
            android:id="@+id/widget_arabic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="إِنَّ مَعَ الْعُسْرِ يُسْرًا"
            android:textSize="14sp"
            android:textColor="#E0E0E0"
            android:textStyle="bold"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:maxLines="2"
            android:ellipsize="end"
            android:lineSpacingMultiplier="1.2" />

        <TextView
            android:id="@+id/widget_translation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="Indeed, with hardship comes ease."
            android:textSize="10sp"
            android:textColor="#888888"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:maxLines="1"
            android:ellipsize="end"
            android:textStyle="italic" />

    </LinearLayout>

    <!-- Right: Source badge (25%) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/widget_task_header_gradient_dark">

        <TextView
            android:id="@+id/widget_type_emoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📖"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/widget_source"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="94:6"
            android:textSize="9sp"
            android:textColor="#FFFFFF"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:maxLines="1" />

    </LinearLayout>

</LinearLayout>
