<?xml version="1.0" encoding="utf-8"?>
<!-- Combined Prayer Widget — Light LTR 4x1 compact -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_v3_bg_light"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="7dp"
    android:paddingBottom="5dp">

    <!-- Tab Bar -->
    <LinearLayout
        android:id="@+id/tab_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="2dp">

        <TextView
            android:id="@+id/tab_next_prayer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Next Prayer"
            android:textSize="10sp"
            android:textColor="#B5821B"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold"
            android:letterSpacing="0.06"
            android:gravity="center"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="1dp"
            android:paddingBottom="1dp"
            android:background="@drawable/widget_tab_active_light"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/tab_timeline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="All Prayer"
            android:textSize="10sp"
            android:textColor="#9A8F78"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold"
            android:letterSpacing="0.06"
            android:gravity="center"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="1dp"
            android:paddingBottom="1dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/widget_tab_inactive_light"
            android:clickable="true"
            android:focusable="true" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="9dp"
                android:layout_height="9dp"
                android:src="@drawable/widget_location_pin"
                android:scaleType="fitCenter"
                android:layout_marginEnd="2dp" />

            <TextView
                android:id="@+id/widget_location_small"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Riyadh"
                android:textSize="8sp"
                android:textColor="#7A6E5A" />
        </LinearLayout>
    </LinearLayout>

    <!-- ViewFlipper -->
    <ViewFlipper
        android:id="@+id/view_flipper"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- ═══ View 0: Next Prayer ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Left: prayer info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.4"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/widget_next_prayer_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Asr"
                        android:textSize="24sp"
                        android:textColor="#2A2418"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/widget_next_prayer_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="03:25"
                        android:textSize="14sp"
                        android:textColor="#B5821B"
                        android:fontFamily="monospace"
                        android:layout_marginStart="8dp" />

                    <TextView
                        android:id="@+id/widget_next_prayer_ampm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PM"
                        android:textSize="10sp"
                        android:textColor="#7A6E5A"
                        android:layout_marginStart="2dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="3dp"
                    android:background="@drawable/widget_v3_pill_light"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp">

                    <ImageView
                        android:id="@+id/widget_progress_bar"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:scaleType="fitCenter" />

                    <Chronometer
                        android:id="@+id/widget_time_remaining"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="#8A6110"
                        android:fontFamily="monospace"
                        android:countDown="true"
                        android:layout_marginStart="6dp" />

                    <TextView
                        android:id="@+id/widget_time_remaining_seconds"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="UNTIL AZAN"
                        android:textSize="7sp"
                        android:textColor="#7A6E5A"
                        android:fontFamily="monospace"
                        android:layout_marginStart="3dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Right: date card -->
            <LinearLayout
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:orientation="vertical"
                android:background="@drawable/widget_v3_panel_light"
                android:padding="6dp"
                android:layout_marginStart="8dp">

                <TextView
                    android:id="@+id/widget_day_of_week"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tuesday"
                    android:textSize="8sp"
                    android:textColor="#B5821B"
                    android:fontFamily="sans-serif-medium"
                    android:textStyle="bold"
                    android:gravity="center" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="2dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/widget_gregorian_label"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="GREGORIAN"
                            android:textSize="5sp"
                            android:textColor="#9A8F78"
                            android:fontFamily="monospace"
                            android:letterSpacing="0.08"
                            android:gravity="center" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/widget_gregorian_day"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="21"
                                android:textSize="11sp"
                                android:textColor="#2A2418"
                                android:fontFamily="sans-serif-medium"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/widget_gregorian_month"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Apr"
                                android:textSize="11sp"
                                android:textColor="#B5821B"
                                android:fontFamily="sans-serif-medium"
                                android:textStyle="bold"
                                android:layout_marginStart="3dp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/widget_gregorian_year"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="2026"
                            android:textSize="6sp"
                            android:textColor="#9A8F78"
                            android:fontFamily="monospace"
                            android:gravity="center" />
                    </LinearLayout>

                    <FrameLayout
                        android:layout_width="1dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center_vertical"
                        android:layout_marginStart="2dp"
                        android:layout_marginEnd="2dp"
                        android:background="#1A3C2D14" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/widget_hijri_label"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="HIJRI"
                            android:textSize="5sp"
                            android:textColor="#9A8F78"
                            android:fontFamily="monospace"
                            android:letterSpacing="0.08"
                            android:gravity="center" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/widget_hijri_day"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="4"
                                android:textSize="11sp"
                                android:textColor="#2A2418"
                                android:fontFamily="sans-serif-medium"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/widget_hijri_month"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Dhu Q."
                                android:layout_marginStart="3dp"
                                android:textSize="11sp"
                                android:textColor="#B5821B"
                                android:fontFamily="sans-serif-medium"
                                android:textStyle="bold"
                                android:maxLines="1"
                                android:ellipsize="end" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/widget_hijri_year"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="1447 AH"
                            android:textSize="6sp"
                            android:textColor="#9A8F78"
                            android:fontFamily="monospace"
                            android:gravity="center" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ═══ View 1: Day Timeline ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_vertical">

            <!-- Header: current prayer + next countdown in ONE row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom">

                <!-- Left: current prayer name + time -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="bottom">

                    <TextView
                        android:id="@+id/timeline_current_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Zuhr"
                        android:textSize="14sp"
                        android:textColor="#2A2418"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/timeline_current_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="11:52"
                        android:textSize="11sp"
                        android:textColor="#B5821B"
                        android:fontFamily="monospace"
                        android:layout_marginStart="4dp" />

                    <TextView
                        android:id="@+id/timeline_current_ampm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AM"
                        android:textSize="8sp"
                        android:textColor="#7A6E5A"
                        android:layout_marginStart="2dp" />
                </LinearLayout>

                <!-- Right: NEXT label + prayer name + countdown -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="bottom"
                    android:baselineAligned="false">

                    <TextView
                        android:id="@+id/timeline_next_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NEXT · "
                        android:textSize="7sp"
                        android:textColor="#7A6E5A"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.06" />

                    <TextView
                        android:id="@+id/timeline_next_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ASR"
                        android:textSize="11sp"
                        android:textColor="#B5821B"
                        android:fontFamily="monospace"
                        android:textStyle="bold"
                        android:letterSpacing="0.06" />

                    <TextView
                        android:id="@+id/timeline_next_suffix"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" IN"
                        android:textSize="7sp"
                        android:textColor="#7A6E5A"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.06" />

                    <Chronometer
                        android:id="@+id/timeline_countdown_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="#B5821B"
                        android:fontFamily="sans-serif-medium"
                        android:textStyle="bold"
                        android:countDown="true"
                        android:layout_marginStart="6dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Hidden secondary info (kept for Kotlin compat) -->
            <TextView
                android:id="@+id/timeline_secondary_info"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:text=""
                android:visibility="gone" />

            <!-- Timeline: bar through dots -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp">

                <ImageView
                    android:id="@+id/timeline_progress_bar"
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:layout_gravity="top"
                    android:layout_marginTop="3dp"
                    android:scaleType="fitXY" />

                <!-- 6 prayer dots row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Fajr -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
                        <ImageView android:id="@+id/timeline_dot_0" android:layout_width="8dp" android:layout_height="8dp" android:scaleType="fitCenter" />
                        <TextView android:id="@+id/timeline_name_0" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Fajr" android:textSize="6sp" android:textColor="#9A8F78" android:maxLines="1" android:layout_marginTop="1dp" />
                        <TextView android:id="@+id/timeline_time_0" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="04:21" android:textSize="6sp" android:textColor="#9A8F78" android:fontFamily="monospace" />
                    </LinearLayout>

                    <!-- Sunrise -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
                        <ImageView android:id="@+id/timeline_dot_1" android:layout_width="8dp" android:layout_height="8dp" android:scaleType="fitCenter" />
                        <TextView android:id="@+id/timeline_name_1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Shuruq" android:textSize="6sp" android:textColor="#9A8F78" android:maxLines="1" android:layout_marginTop="1dp" />
                        <TextView android:id="@+id/timeline_time_1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="05:47" android:textSize="6sp" android:textColor="#9A8F78" android:fontFamily="monospace" />
                    </LinearLayout>

                    <!-- Zuhr -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
                        <ImageView android:id="@+id/timeline_dot_2" android:layout_width="8dp" android:layout_height="8dp" android:scaleType="fitCenter" />
                        <TextView android:id="@+id/timeline_name_2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Zuhr" android:textSize="6sp" android:textColor="#2A2418" android:textStyle="bold" android:maxLines="1" android:layout_marginTop="1dp" />
                        <TextView android:id="@+id/timeline_time_2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="11:52" android:textSize="6sp" android:textColor="#2A2418" android:fontFamily="monospace" />
                    </LinearLayout>

                    <!-- Asr -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
                        <ImageView android:id="@+id/timeline_dot_3" android:layout_width="8dp" android:layout_height="8dp" android:scaleType="fitCenter" />
                        <TextView android:id="@+id/timeline_name_3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Asr" android:textSize="6sp" android:textColor="#8A6110" android:textStyle="bold" android:maxLines="1" android:layout_marginTop="1dp" />
                        <TextView android:id="@+id/timeline_time_3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="15:14" android:textSize="6sp" android:textColor="#8A6110" android:fontFamily="monospace" />
                    </LinearLayout>

                    <!-- Maghrib -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
                        <ImageView android:id="@+id/timeline_dot_4" android:layout_width="8dp" android:layout_height="8dp" android:scaleType="fitCenter" />
                        <TextView android:id="@+id/timeline_name_4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Maghrib" android:textSize="6sp" android:textColor="#9A8F78" android:maxLines="1" android:layout_marginTop="1dp" />
                        <TextView android:id="@+id/timeline_time_4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="18:29" android:textSize="6sp" android:textColor="#9A8F78" android:fontFamily="monospace" />
                    </LinearLayout>

                    <!-- Isha -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
                        <ImageView android:id="@+id/timeline_dot_5" android:layout_width="8dp" android:layout_height="8dp" android:scaleType="fitCenter" />
                        <TextView android:id="@+id/timeline_name_5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Isha" android:textSize="6sp" android:textColor="#9A8F78" android:maxLines="1" android:layout_marginTop="1dp" />
                        <TextView android:id="@+id/timeline_time_5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="19:52" android:textSize="6sp" android:textColor="#9A8F78" android:fontFamily="monospace" />
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>
        </LinearLayout>
    </ViewFlipper>
</LinearLayout>
