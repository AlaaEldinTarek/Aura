<?xml version="1.0" encoding="utf-8"?>
<!-- Combined Prayer Widget — Dark LTR (4x3) with ViewFlipper -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_v3_bg_dark"
    android:paddingStart="14dp"
    android:paddingEnd="14dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <!-- Tab Bar -->
    <LinearLayout
        android:id="@+id/tab_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView
            android:id="@+id/tab_next_prayer"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:text="Next Prayer"
            android:textSize="10sp"
            android:textColor="#F5B301"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold"
            android:letterSpacing="0.06"
            android:gravity="center"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:background="@drawable/widget_tab_active_dark"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/tab_timeline"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:text="Timeline"
            android:textSize="10sp"
            android:textColor="#6B7180"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold"
            android:letterSpacing="0.06"
            android:gravity="center"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/widget_tab_inactive_dark"
            android:clickable="true"
            android:focusable="true" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:src="@drawable/widget_location_pin"
                android:scaleType="fitCenter"
                android:layout_marginEnd="3dp" />

            <TextView
                android:id="@+id/widget_location_small"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Riyadh"
                android:textSize="8sp"
                android:textColor="#A8ADB8" />
        </LinearLayout>
    </LinearLayout>

    <!-- ViewFlipper: Next Prayer (0) and Timeline (1) -->
    <ViewFlipper
        android:id="@+id/view_flipper"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- ═══ View 0: Next Prayer (same as NextPrayerWidget) ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Left: prayer info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.4"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/widget_next_prayer_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Asr"
                        android:textSize="34sp"
                        android:textColor="#F4F5F7"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/widget_next_prayer_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="03:25"
                        android:textSize="20sp"
                        android:textColor="#F5B301"
                        android:fontFamily="monospace"
                        android:layout_marginStart="10dp" />

                    <TextView
                        android:id="@+id/widget_next_prayer_ampm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PM"
                        android:textSize="15sp"
                        android:textColor="#A8ADB8"
                        android:layout_marginStart="3dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="6dp"
                    android:background="@drawable/widget_v3_pill_dark"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:minHeight="28dp">

                    <ImageView
                        android:id="@+id/widget_progress_bar"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:scaleType="fitCenter" />

                    <Chronometer
                        android:id="@+id/widget_time_remaining"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:textColor="#FFD37A"
                        android:fontFamily="monospace"
                        android:countDown="true"
                        android:layout_marginStart="8dp" />

                    <TextView
                        android:id="@+id/widget_time_remaining_seconds"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="UNTIL AZAN"
                        android:textSize="8sp"
                        android:textColor="#A8ADB8"
                        android:fontFamily="monospace"
                        android:layout_marginStart="4dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Right: date card -->
            <LinearLayout
                android:layout_width="140dp"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:background="@drawable/widget_v3_panel_dark"
                android:padding="10dp"
                android:layout_marginStart="10dp">

                <TextView
                    android:id="@+id/widget_day_of_week"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tuesday"
                    android:textSize="10sp"
                    android:textColor="#F5B301"
                    android:fontFamily="sans-serif-medium"
                    android:textStyle="bold"
                    android:gravity="center" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:layout_marginTop="2dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/widget_gregorian_label"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="GREGORIAN"
                            android:textSize="6sp"
                            android:textColor="#6B7180"
                            android:fontFamily="monospace"
                            android:letterSpacing="0.12"
                            android:gravity="center" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/widget_gregorian_day"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="21"
                                android:textSize="14sp"
                                android:textColor="#F4F5F7"
                                android:fontFamily="sans-serif-medium"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/widget_gregorian_month"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Apr"
                                android:textSize="14sp"
                                android:textColor="#F5B301"
                                android:fontFamily="sans-serif-medium"
                                android:textStyle="bold"
                                android:layout_marginStart="4dp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/widget_gregorian_year"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="2026"
                            android:textSize="8sp"
                            android:textColor="#6B7180"
                            android:fontFamily="monospace"
                            android:gravity="center" />
                    </LinearLayout>

                    <FrameLayout
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="3dp"
                        android:layout_marginEnd="3dp"
                        android:background="#1EFFFFFF" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/widget_hijri_label"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="HIJRI"
                            android:textSize="6sp"
                            android:textColor="#6B7180"
                            android:fontFamily="monospace"
                            android:letterSpacing="0.12"
                            android:gravity="center" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/widget_hijri_day"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="4"
                                android:textSize="14sp"
                                android:textColor="#F4F5F7"
                                android:fontFamily="sans-serif-medium"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/widget_hijri_month"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Dhu al-Qadah"
                                android:layout_marginStart="4dp"
                                android:textSize="14sp"
                                android:textColor="#F5B301"
                                android:fontFamily="sans-serif-medium"
                                android:textStyle="bold"
                                android:maxLines="1"
                                android:ellipsize="end" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/widget_hijri_year"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="1447 AH"
                            android:textSize="8sp"
                            android:textColor="#6B7180"
                            android:fontFamily="monospace"
                            android:gravity="center" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ═══ View 1: Day Timeline ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Top section: Current prayer info + countdown -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Left: Current prayer -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/timeline_current_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Zuhr"
                        android:textSize="28sp"
                        android:textColor="#F4F5F7"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="2dp">

                        <TextView
                            android:id="@+id/timeline_current_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="11:52"
                            android:textSize="16sp"
                            android:textColor="#F5B301"
                            android:fontFamily="monospace" />

                        <TextView
                            android:id="@+id/timeline_current_ampm"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AM"
                            android:textSize="12sp"
                            android:textColor="#A8ADB8"
                            android:layout_marginStart="2dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Right: Next countdown -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:id="@+id/timeline_next_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NEXT · ASR IN"
                        android:textSize="8sp"
                        android:textColor="#A8ADB8"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:id="@+id/timeline_countdown_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1h 02m"
                        android:textSize="22sp"
                        android:textColor="#F5B301"
                        android:fontFamily="sans-serif-medium"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp" />

                    <TextView
                        android:id="@+id/timeline_secondary_info"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TUE 21 APR"
                        android:textSize="7sp"
                        android:textColor="#6B7180"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.06"
                        android:layout_marginTop="1dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Timeline: bar through dots -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp">

                <ImageView
                    android:id="@+id/timeline_progress_bar"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:layout_gravity="top"
                    android:layout_marginTop="4dp"
                    android:scaleType="fitXY" />

            <!-- 6 prayer dots row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Fajr -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">

                    <ImageView
                        android:id="@+id/timeline_dot_0"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:scaleType="fitCenter" />

                    <TextView
                        android:id="@+id/timeline_name_0"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fajr"
                        android:textSize="8sp"
                        android:textColor="#6B7180"
                        android:maxLines="1"
                        android:layout_marginTop="3dp" />

                    <TextView
                        android:id="@+id/timeline_time_0"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="04:21"
                        android:textSize="7sp"
                        android:textColor="#6B7180"
                        android:fontFamily="monospace" />
                </LinearLayout>

                <!-- Sunrise -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">

                    <ImageView
                        android:id="@+id/timeline_dot_1"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:scaleType="fitCenter" />

                    <TextView
                        android:id="@+id/timeline_name_1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Shuruq"
                        android:textSize="8sp"
                        android:textColor="#6B7180"
                        android:maxLines="1"
                        android:layout_marginTop="3dp" />

                    <TextView
                        android:id="@+id/timeline_time_1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="05:47"
                        android:textSize="7sp"
                        android:textColor="#6B7180"
                        android:fontFamily="monospace" />
                </LinearLayout>

                <!-- Dhuhr -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">

                    <ImageView
                        android:id="@+id/timeline_dot_2"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:scaleType="fitCenter" />

                    <TextView
                        android:id="@+id/timeline_name_2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Zuhr"
                        android:textSize="8sp"
                        android:textColor="#F4F5F7"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:layout_marginTop="3dp" />

                    <TextView
                        android:id="@+id/timeline_time_2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="11:52"
                        android:textSize="7sp"
                        android:textColor="#F4F5F7"
                        android:fontFamily="monospace" />
                </LinearLayout>

                <!-- Asr -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">

                    <ImageView
                        android:id="@+id/timeline_dot_3"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:scaleType="fitCenter" />

                    <TextView
                        android:id="@+id/timeline_name_3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Asr"
                        android:textSize="8sp"
                        android:textColor="#FFD37A"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:layout_marginTop="3dp" />

                    <TextView
                        android:id="@+id/timeline_time_3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="15:14"
                        android:textSize="7sp"
                        android:textColor="#FFD37A"
                        android:fontFamily="monospace" />
                </LinearLayout>

                <!-- Maghrib -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">

                    <ImageView
                        android:id="@+id/timeline_dot_4"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:scaleType="fitCenter" />

                    <TextView
                        android:id="@+id/timeline_name_4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Maghrib"
                        android:textSize="8sp"
                        android:textColor="#6B7180"
                        android:maxLines="1"
                        android:layout_marginTop="3dp" />

                    <TextView
                        android:id="@+id/timeline_time_4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="18:29"
                        android:textSize="7sp"
                        android:textColor="#6B7180"
                        android:fontFamily="monospace" />
                </LinearLayout>

                <!-- Isha -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">

                    <ImageView
                        android:id="@+id/timeline_dot_5"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:scaleType="fitCenter" />

                    <TextView
                        android:id="@+id/timeline_name_5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Isha"
                        android:textSize="8sp"
                        android:textColor="#6B7180"
                        android:maxLines="1"
                        android:layout_marginTop="3dp" />

                    <TextView
                        android:id="@+id/timeline_time_5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="19:52"
                        android:textSize="7sp"
                        android:textColor="#6B7180"
                        android:fontFamily="monospace" />
                </LinearLayout>
            </LinearLayout>
            </FrameLayout>
        </LinearLayout>
    </ViewFlipper>
</LinearLayout>
