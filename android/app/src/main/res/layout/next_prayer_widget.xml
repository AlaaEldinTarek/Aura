<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@drawable/widget_card_modern_light"
    android:padding="3dp">

    <!-- Left Section - Prayer Info (30%) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="3.0"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:paddingEnd="8dp"
        android:gravity="center_vertical">

        <!-- Prayer Name -->
        <TextView
            android:id="@+id/widget_next_prayer_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Asr"
            android:textSize="17sp"
            android:textColor="#1A1A1A"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Prayer Time Container -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="2dp">

            <!-- Time -->
            <TextView
                android:id="@+id/widget_next_prayer_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="03:25"
                android:textSize="20sp"
                android:textColor="#007DFF"
                android:fontFamily="monospace" />

            <!-- AM/PM -->
            <TextView
                android:id="@+id/widget_next_prayer_ampm"
                android:layout_width="35dp"
                android:layout_height="wrap_content"
                android:text="PM"
                android:textSize="11sp"
                android:textColor="#007DFF"
                android:layout_marginStart="2dp"
                android:maxLines="1"
                android:ellipsize="none"
                android:gravity="start" />
        </LinearLayout>

        <!-- Location -->
        <TextView
            android:id="@+id/widget_location_small"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Riyadh"
            android:textSize="10sp"
            android:textColor="#757575"
            android:layout_marginTop="3dp"
            android:maxLines="1"
            android:ellipsize="end"
            android:drawableLeft="@drawable/ic_location_small"
            android:drawablePadding="3dp" />
    </LinearLayout>

    <!-- Middle - Time Remaining (45%) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="4.5"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Time Remaining Badge - 100% of container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="7dp"
            android:layout_marginBottom="7dp"
            android:layout_marginStart="7dp"
            android:layout_marginEnd="7dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:background="@drawable/widget_countdown_modern">

            <!-- "Next Prayer" Label -->
            <TextView
                android:id="@+id/widget_next_prayer_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Next Prayer"
                android:textSize="9sp"
                android:textColor="#D0D0D0"
                android:textAllCaps="true"
                android:letterSpacing="0.05" />

            <!-- Time Remaining -->
            <TextView
                android:id="@+id/widget_time_remaining"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2 h 30 m"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />

            <!-- Seconds Countdown -->
            <TextView
                android:id="@+id/widget_time_remaining_seconds"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="45 sec"
                android:textSize="11sp"
                android:textColor="#E0E0E0"
                android:layout_marginTop="2dp"
                android:alpha="0.9" />

            <!-- Progress Bar - Bigger with rounded corners -->
            <ProgressBar
                android:id="@+id/widget_progress_bar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:layout_marginTop="4dp"
                android:progress="30"
                android:max="60"
                android:progressTint="#FFFFFF"
                android:progressBackgroundTint="#B0FFFFFF"
                android:progressDrawable="@drawable/progress_bar_rounded" />
        </LinearLayout>
    </LinearLayout>

    <!-- Combined Date Card (25%) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="2.5"
        android:orientation="vertical"
        android:layout_marginStart="7dp"
        android:layout_marginEnd="7dp"
        android:layout_marginTop="7dp"
        android:layout_marginBottom="7dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:gravity="center"
        android:background="@drawable/widget_date_glass_light">

        <!-- Day of Week -->
        <TextView
            android:id="@+id/widget_day_of_week"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thursday"
            android:textSize="10sp"
            android:textColor="#007DFF"
            android:textStyle="bold" />

        <!-- Gregorian Date -->
        <TextView
            android:id="@+id/widget_gregorian_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Apr 3, 2026"
            android:textSize="11sp"
            android:textColor="#007DFF"
            android:layout_marginTop="4dp" />

        <!-- Hijri Date -->
        <TextView
            android:id="@+id/widget_hijri_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ram 25, 1446"
            android:textSize="10sp"
            android:textColor="#007DFF"
            android:alpha="0.7"
            android:layout_marginTop="4dp" />
    </LinearLayout>

</LinearLayout>
