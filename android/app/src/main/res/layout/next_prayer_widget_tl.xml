<?xml version="1.0" encoding="utf-8"?>
<!-- Timeline-only layout for Next Prayer Widget — Light LTR (compact 4x1) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@drawable/widget_v3_bg_light"
    android:paddingStart="10dp"
    android:paddingEnd="10dp"
    android:paddingTop="4dp"
    android:paddingBottom="4dp"
    android:gravity="center_vertical">

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
        <ImageView android:id="@+id/timeline_dot_0" android:layout_width="12dp" android:layout_height="12dp" android:scaleType="fitCenter" />
        <TextView android:id="@+id/timeline_name_0" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Fajr" android:textSize="8sp" android:textColor="#9A8F78" android:fontFamily="sans-serif-medium" android:maxLines="1" android:layout_marginTop="3dp" />
        <TextView android:id="@+id/timeline_time_0" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="04:21" android:textSize="7sp" android:textColor="#9A8F78" android:fontFamily="monospace" android:textDirection="ltr" />
    </LinearLayout>

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
        <ImageView android:id="@+id/timeline_dot_1" android:layout_width="12dp" android:layout_height="12dp" android:scaleType="fitCenter" />
        <TextView android:id="@+id/timeline_name_1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Shuruq" android:textSize="8sp" android:textColor="#9A8F78" android:fontFamily="sans-serif-medium" android:maxLines="1" android:layout_marginTop="3dp" />
        <TextView android:id="@+id/timeline_time_1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="05:47" android:textSize="7sp" android:textColor="#9A8F78" android:fontFamily="monospace" android:textDirection="ltr" />
    </LinearLayout>

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
        <ImageView android:id="@+id/timeline_dot_2" android:layout_width="12dp" android:layout_height="12dp" android:scaleType="fitCenter" />
        <TextView android:id="@+id/timeline_name_2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Zuhr" android:textSize="8sp" android:textColor="#9A8F78" android:fontFamily="sans-serif-medium" android:maxLines="1" android:layout_marginTop="3dp" />
        <TextView android:id="@+id/timeline_time_2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="11:52" android:textSize="7sp" android:textColor="#9A8F78" android:fontFamily="monospace" android:textDirection="ltr" />
    </LinearLayout>

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
        <ImageView android:id="@+id/timeline_dot_3" android:layout_width="12dp" android:layout_height="12dp" android:scaleType="fitCenter" />
        <TextView android:id="@+id/timeline_name_3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Asr" android:textSize="8sp" android:textColor="#9A8F78" android:fontFamily="sans-serif-medium" android:maxLines="1" android:layout_marginTop="3dp" />
        <TextView android:id="@+id/timeline_time_3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="15:14" android:textSize="7sp" android:textColor="#9A8F78" android:fontFamily="monospace" android:textDirection="ltr" />
    </LinearLayout>

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
        <ImageView android:id="@+id/timeline_dot_4" android:layout_width="12dp" android:layout_height="12dp" android:scaleType="fitCenter" />
        <TextView android:id="@+id/timeline_name_4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Maghrib" android:textSize="8sp" android:textColor="#9A8F78" android:fontFamily="sans-serif-medium" android:maxLines="1" android:layout_marginTop="3dp" />
        <TextView android:id="@+id/timeline_time_4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="18:29" android:textSize="7sp" android:textColor="#9A8F78" android:fontFamily="monospace" android:textDirection="ltr" />
    </LinearLayout>

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
        <ImageView android:id="@+id/timeline_dot_5" android:layout_width="12dp" android:layout_height="12dp" android:scaleType="fitCenter" />
        <TextView android:id="@+id/timeline_name_5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Isha" android:textSize="8sp" android:textColor="#9A8F78" android:fontFamily="sans-serif-medium" android:maxLines="1" android:layout_marginTop="3dp" />
        <TextView android:id="@+id/timeline_time_5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="19:52" android:textSize="7sp" android:textColor="#9A8F78" android:fontFamily="monospace" android:textDirection="ltr" />
    </LinearLayout>
</LinearLayout>
