<?xml version="1.0" encoding="utf-8"?>
<!-- Timeline-only layout for Next Prayer Widget — Dark RTL (compact 4x1) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:layoutDirection="ltr"
    android:background="@drawable/widget_v3_bg_dark"
    android:paddingStart="10dp"
    android:paddingEnd="10dp"
    android:paddingTop="4dp"
    android:paddingBottom="4dp"
    android:gravity="center_vertical">

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
        <ImageView android:id="@+id/timeline_dot_0" android:layout_width="12dp" android:layout_height="12dp" android:scaleType="fitCenter" />
        <TextView android:id="@+id/timeline_name_0" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="الفجر" android:textSize="8sp" android:textColor="#6B7180" android:fontFamily="sans-serif-medium" android:maxLines="1" android:layout_marginTop="3dp" />
        <TextView android:id="@+id/timeline_time_0" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="٠٤:٢١" android:textSize="7sp" android:textColor="#6B7180" android:fontFamily="monospace" android:textDirection="ltr" />
    </LinearLayout>

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
        <ImageView android:id="@+id/timeline_dot_1" android:layout_width="12dp" android:layout_height="12dp" android:scaleType="fitCenter" />
        <TextView android:id="@+id/timeline_name_1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="الشروق" android:textSize="8sp" android:textColor="#6B7180" android:fontFamily="sans-serif-medium" android:maxLines="1" android:layout_marginTop="3dp" />
        <TextView android:id="@+id/timeline_time_1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="٠٥:٤٧" android:textSize="7sp" android:textColor="#6B7180" android:fontFamily="monospace" android:textDirection="ltr" />
    </LinearLayout>

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
        <ImageView android:id="@+id/timeline_dot_2" android:layout_width="12dp" android:layout_height="12dp" android:scaleType="fitCenter" />
        <TextView android:id="@+id/timeline_name_2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="الظهر" android:textSize="8sp" android:textColor="#6B7180" android:fontFamily="sans-serif-medium" android:maxLines="1" android:layout_marginTop="3dp" />
        <TextView android:id="@+id/timeline_time_2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="١١:٥٢" android:textSize="7sp" android:textColor="#6B7180" android:fontFamily="monospace" android:textDirection="ltr" />
    </LinearLayout>

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
        <ImageView android:id="@+id/timeline_dot_3" android:layout_width="12dp" android:layout_height="12dp" android:scaleType="fitCenter" />
        <TextView android:id="@+id/timeline_name_3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="العصر" android:textSize="8sp" android:textColor="#6B7180" android:fontFamily="sans-serif-medium" android:maxLines="1" android:layout_marginTop="3dp" />
        <TextView android:id="@+id/timeline_time_3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="١٥:١٤" android:textSize="7sp" android:textColor="#6B7180" android:fontFamily="monospace" android:textDirection="ltr" />
    </LinearLayout>

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
        <ImageView android:id="@+id/timeline_dot_4" android:layout_width="12dp" android:layout_height="12dp" android:scaleType="fitCenter" />
        <TextView android:id="@+id/timeline_name_4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="المغرب" android:textSize="8sp" android:textColor="#6B7180" android:fontFamily="sans-serif-medium" android:maxLines="1" android:layout_marginTop="3dp" />
        <TextView android:id="@+id/timeline_time_4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="١٨:٢٩" android:textSize="7sp" android:textColor="#6B7180" android:fontFamily="monospace" android:textDirection="ltr" />
    </LinearLayout>

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
        <ImageView android:id="@+id/timeline_dot_5" android:layout_width="12dp" android:layout_height="12dp" android:scaleType="fitCenter" />
        <TextView android:id="@+id/timeline_name_5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="العشاء" android:textSize="8sp" android:textColor="#6B7180" android:fontFamily="sans-serif-medium" android:maxLines="1" android:layout_marginTop="3dp" />
        <TextView android:id="@+id/timeline_time_5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="١٩:٥٢" android:textSize="7sp" android:textColor="#6B7180" android:fontFamily="monospace" android:textDirection="ltr" />
    </LinearLayout>
</LinearLayout>
