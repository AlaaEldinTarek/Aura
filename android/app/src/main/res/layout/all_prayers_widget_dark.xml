<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="0dp"
    android:background="@drawable/widget_all_prayer_background_dark"
    >

    <!-- Header with gradient -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:background="@drawable/widget_all_header_gradient_dark">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🕌"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/widget_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="Prayer Times"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/widget_location_small"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="..."
            android:textSize="10sp"
            android:textColor="#FFFFFF"
            android:fontFamily="sans-serif"
            android:drawableLeft="@drawable/ic_location_small"
            android:drawablePadding="3dp" />
    </LinearLayout>

    <!-- Prayer Times List -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp">

        <!-- Fajr -->
        <FrameLayout
            android:id="@+id/widget_fajr_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="6dp"
            android:background="@drawable/prayer_card_selector_dark">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌙"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/widget_fajr_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="Fajr"
                    android:textSize="14sp"
                    android:textColor="#E0E0E0"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/widget_fajr_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--:--"
                    android:textSize="14sp"
                    android:textColor="#888888"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <TextView
                android:id="@+id/widget_fajr_now"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Now Pray"
                android:textSize="12sp"
                android:textColor="#4DA6FF"
                android:textStyle="bold"
                android:layout_gravity="center"
                android:visibility="gone" />

            <TextView
                android:id="@+id/widget_fajr_next"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Next Pray"
                android:textSize="12sp"
                android:textColor="#4DA6FF"
                android:textStyle="bold"
                android:layout_gravity="center"
                android:visibility="gone" />
        </FrameLayout>

        <!-- Sunrise -->
        <FrameLayout
            android:id="@+id/widget_sunrise_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:background="@drawable/prayer_card_selector_dark">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌅"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/widget_sunrise_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="Sunrise"
                    android:textSize="14sp"
                    android:textColor="#888888"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/widget_sunrise_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--:--"
                    android:textSize="12sp"
                    android:textColor="#888888"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <TextView
                android:id="@+id/widget_sunrise_now"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Now Pray"
                android:textSize="8sp"
                android:textColor="#FFFFFF"
                android:background="#888888"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:layout_gravity="center"
                android:visibility="gone" />

            <TextView
                android:id="@+id/widget_sunrise_next"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Next Pray"
                android:textSize="12sp"
                android:textColor="#4DA6FF"
                android:textStyle="bold"
                android:layout_gravity="center"
                android:visibility="gone" />
        </FrameLayout>

        <!-- Dhuhr -->
        <FrameLayout
            android:id="@+id/widget_dhuhr_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:background="@drawable/prayer_card_selector_dark">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="☀️"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/widget_dhuhr_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="Dhuhr"
                    android:textSize="14sp"
                    android:textColor="#E0E0E0"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/widget_dhuhr_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--:--"
                    android:textSize="14sp"
                    android:textColor="#888888"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <TextView
                android:id="@+id/widget_dhuhr_now"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Now Pray"
                android:textSize="12sp"
                android:textColor="#4DA6FF"
                android:textStyle="bold"
                android:layout_gravity="center"
                android:visibility="gone" />

            <TextView
                android:id="@+id/widget_dhuhr_next"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Next Pray"
                android:textSize="12sp"
                android:textColor="#4DA6FF"
                android:textStyle="bold"
                android:layout_gravity="center"
                android:visibility="gone" />
        </FrameLayout>

        <!-- Asr -->
        <FrameLayout
            android:id="@+id/widget_asr_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:background="@drawable/prayer_card_selector_dark">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌤️"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/widget_asr_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="Asr"
                    android:textSize="14sp"
                    android:textColor="#E0E0E0"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/widget_asr_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--:--"
                    android:textSize="14sp"
                    android:textColor="#888888"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <TextView
                android:id="@+id/widget_asr_now"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Now Pray"
                android:textSize="12sp"
                android:textColor="#4DA6FF"
                android:textStyle="bold"
                android:layout_gravity="center"
                android:visibility="gone" />

            <TextView
                android:id="@+id/widget_asr_next"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Next Pray"
                android:textSize="12sp"
                android:textColor="#4DA6FF"
                android:textStyle="bold"
                android:layout_gravity="center"
                android:visibility="gone" />
        </FrameLayout>

        <!-- Maghrib -->
        <FrameLayout
            android:id="@+id/widget_maghrib_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:background="@drawable/prayer_card_selector_dark">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌆"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/widget_maghrib_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="Maghrib"
                    android:textSize="14sp"
                    android:textColor="#E0E0E0"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/widget_maghrib_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--:--"
                    android:textSize="14sp"
                    android:textColor="#888888"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <TextView
                android:id="@+id/widget_maghrib_now"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Now Pray"
                android:textSize="12sp"
                android:textColor="#4DA6FF"
                android:textStyle="bold"
                android:layout_gravity="center"
                android:visibility="gone" />

            <TextView
                android:id="@+id/widget_maghrib_next"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Next Pray"
                android:textSize="12sp"
                android:textColor="#4DA6FF"
                android:textStyle="bold"
                android:layout_gravity="center"
                android:visibility="gone" />
        </FrameLayout>

        <!-- Isha -->
        <FrameLayout
            android:id="@+id/widget_isha_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/prayer_card_selector_dark">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌙"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/widget_isha_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="Isha"
                    android:textSize="14sp"
                    android:textColor="#E0E0E0"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/widget_isha_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--:--"
                    android:textSize="14sp"
                    android:textColor="#888888"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <TextView
                android:id="@+id/widget_isha_now"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Now Pray"
                android:textSize="12sp"
                android:textColor="#4DA6FF"
                android:textStyle="bold"
                android:layout_gravity="center"
                android:visibility="gone" />

            <TextView
                android:id="@+id/widget_isha_next"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Next Pray"
                android:textSize="12sp"
                android:textColor="#4DA6FF"
                android:textStyle="bold"
                android:layout_gravity="center"
                android:visibility="gone" />
        </FrameLayout>

    </LinearLayout>

</LinearLayout>
