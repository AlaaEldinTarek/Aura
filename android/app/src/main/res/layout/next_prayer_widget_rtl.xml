<?xml version="1.0" encoding="utf-8"?>
<!-- V3 Editorial Skyline — Light RTL (compact 4x1) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:layoutDirection="rtl"
    android:background="@drawable/widget_v3_bg_light"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:gravity="center_vertical">

    <!-- ── Left: prayer info (right side in RTL) ── -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.4"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/widget_location_small"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="الرياض"
                android:textSize="9sp"
                android:textColor="#7A6E5A" />

            <TextView
                android:id="@+id/widget_next_prayer_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="أوقات الصلاة"
                android:textSize="8sp"
                android:textColor="#7A6E5A"
                android:fontFamily="monospace"
                android:gravity="end"
                android:layout_marginEnd="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🕌"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="2dp">

            <TextView
                android:id="@+id/widget_next_prayer_ampm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="مساءً"
                android:textSize="9sp"
                android:textColor="#7A6E5A"
                android:layout_marginEnd="2dp" />

            <TextView
                android:id="@+id/widget_next_prayer_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="٠٣:٢٥"
                android:textSize="13sp"
                android:textColor="#B5821B"
                android:fontFamily="monospace"
                android:textDirection="ltr"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/widget_next_prayer_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="العصر"
                android:textSize="22sp"
                android:textColor="#2A2418"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/widget_v3_pill_light"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:layout_marginTop="3dp"
            android:layout_gravity="end">

            <TextView
                android:id="@+id/widget_time_remaining_seconds"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="حتى الأذان"
                android:textSize="7sp"
                android:textColor="#7A6E5A"
                android:fontFamily="monospace"
                android:layout_marginEnd="3dp" />

            <Chronometer
                android:id="@+id/widget_time_remaining"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="9sp"
                android:textColor="#8A6110"
                android:fontFamily="monospace"
                android:countDown="true"
                android:textDirection="ltr" />

            <ImageView
                android:id="@+id/widget_progress_bar"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:scaleType="fitCenter"
                android:layout_marginStart="6dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- ── Right: date card (left side in RTL) ── -->
    <LinearLayout
        android:layout_width="140dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@drawable/widget_v3_panel_light"
        android:padding="8dp"
        android:layout_marginEnd="8dp">

        <!-- Weekday — centered at top -->
        <TextView
            android:id="@+id/widget_day_of_week"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="الثلاثاء"
            android:textSize="9sp"
            android:textColor="#B5821B"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold"
            android:gravity="center" />

        <!-- Hijri | Gregorian side by side -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginTop="2dp">

            <!-- Hijri (first in RTL = right visual) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/widget_hijri_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="الهجري"
                    android:textSize="6sp"
                    android:textColor="#9A8F78"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.12"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/widget_hijri_date"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="٤ ذو القعدة"
                    android:textSize="9sp"
                    android:textColor="#4A4031"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:maxLines="2"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/widget_hijri_year"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="١٤٤٧ هـ"
                    android:textSize="8sp"
                    android:textColor="#9A8F78"
                    android:fontFamily="monospace"
                    android:gravity="center" />
            </LinearLayout>

            <FrameLayout
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="3dp"
                android:background="#1A3C2D14" />

            <!-- Gregorian (second in RTL = left visual) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/widget_gregorian_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="الميلادي"
                    android:textSize="6sp"
                    android:textColor="#9A8F78"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.12"
                    android:gravity="center" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/widget_gregorian_month"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="أبريل"
                        android:textSize="13sp"
                        android:textColor="#B5821B"
                        android:fontFamily="sans-serif-medium"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/widget_gregorian_day"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" ٢١"
                        android:textSize="13sp"
                        android:textColor="#2A2418"
                        android:fontFamily="sans-serif-medium"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/widget_gregorian_year"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="٢٠٢٦"
                    android:textSize="8sp"
                    android:textColor="#9A8F78"
                    android:fontFamily="monospace"
                    android:gravity="center" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/widget_status_text"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />
</LinearLayout>
