<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_notification"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="4dp"
    android:paddingBottom="4dp"
    android:layoutDirection="rtl"
    android:textDirection="rtl">

    <!-- Header: App icon + Title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="4dp"
        android:layoutDirection="rtl">

        <ImageView
            android:id="@+id/notification_small_icon"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_launcher_foreground"
            android:scaleType="centerCrop" />

        <TextView
            android:id="@+id/notification_header"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="هالة - الصلاة القادمة"
            android:textSize="11sp"
            android:textColor="#99000000"
            android:textDirection="rtl"
            android:letterSpacing="0.03" />

    </LinearLayout>

    <!-- Divider -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1A000000"
        android:layout_marginBottom="6dp" />

    <!-- Content: Prayer info + Icon (RTL) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layoutDirection="rtl">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="12dp"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/notification_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="المغرب"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#DE000000"
                android:textDirection="rtl" />

            <!-- Timer + Until Azan: label first (right in RTL), time after (left) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layoutDirection="rtl">

                <TextView
                    android:id="@+id/notification_until"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="حتى موعد الأذان"
                    android:textSize="12sp"
                    android:textColor="#99000000"
                    android:paddingEnd="8dp"
                    android:textDirection="rtl" />

                <TextView
                    android:id="@+id/notification_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="٢:١٥"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#007DFF"
                    android:textDirection="ltr" />

            </LinearLayout>

        </LinearLayout>

        <ImageView
            android:id="@+id/notification_logo"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:src="@mipmap/ic_launcher"
            android:scaleType="centerCrop"
            android:contentDescription="Prayer Icon" />

    </LinearLayout>

</LinearLayout>
