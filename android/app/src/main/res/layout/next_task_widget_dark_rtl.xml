<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:layoutDirection="rtl"
    android:background="@drawable/widget_task_background_dark"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp"
        android:layoutDirection="rtl">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✅"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/widget_tasks_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="المهمة التالية"
            android:textSize="9sp"
            android:textColor="#F5B301"
            android:fontFamily="sans-serif-medium" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/daily_widget_source_bg_dark"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="1dp"
            android:paddingBottom="1dp">

            <TextView
                android:id="@+id/widget_tasks_done"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="9sp"
                android:textColor="#F5B301"
                android:textDirection="ltr"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/widget_tasks_total_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" / 0"
                android:textSize="9sp"
                android:textColor="#F5B301"
                android:textDirection="ltr"
                android:fontFamily="sans-serif" />

        </LinearLayout>

    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F5B301"
        android:alpha="0.3"
        android:layout_marginBottom="6dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:layoutDirection="rtl">

        <TextView
            android:id="@+id/widget_task_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="لا توجد مهام اليوم"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end"
            android:fontFamily="sans-serif-medium"
            android:textDirection="rtl" />

        <TextView
            android:id="@+id/widget_streak"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="9sp"
            android:textColor="#B0B0B0"
            android:fontFamily="sans-serif"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/widget_task_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="10sp"
            android:textColor="#F5B301"
            android:fontFamily="monospace"
            android:visibility="gone"
            android:textDirection="ltr"
            android:layout_marginTop="2dp" />

    </LinearLayout>

</LinearLayout>
