<?xml version="1.0" encoding="utf-8"?>
<!-- Full-Screen Adhan Layout - Modern design with gradient and prayer icon -->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_adhan_fullscreen">

    <!-- Bismillah at top -->
    <TextView
        android:id="@+id/bismillah"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="48dp"
        android:text="بسم الله الرحمن الرحيم"
        android:textSize="20sp"
        android:textColor="#4DFFFFFF" />

    <!-- Dismiss X button at top right -->
    <Button
        android:id="@+id/btnDismiss"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:text="✕"
        android:textSize="20sp"
        android:textColor="#CCFFFFFF"
        android:background="@drawable/bg_dismiss_circle"
        android:textAllCaps="false"
        android:elevation="4dp" />

    <!-- Center content -->
    <LinearLayout
        android:id="@+id/contentCenter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_centerInParent="true">

        <!-- Prayer Icon with circular glow background -->
        <FrameLayout
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_marginBottom="28dp">

            <!-- Glow circle -->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/bg_prayer_icon_glow" />

            <!-- Prayer icon -->
            <ImageView
                android:id="@+id/prayerIcon"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                android:src="@mipmap/ic_launcher" />

        </FrameLayout>

        <!-- Prayer Name -->
        <TextView
            android:id="@+id/prayerTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Maghrib"
            android:textSize="52sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="4dp" />

        <!-- Time -->
        <TextView
            android:id="@+id/prayerTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="18:14"
            android:textSize="30sp"
            android:textColor="#80FFFFFF"
            android:layout_marginBottom="20dp" />

        <!-- Divider line -->
        <View
            android:layout_width="48dp"
            android:layout_height="2dp"
            android:background="#33FFFFFF"
            android:layout_marginBottom="20dp" />

        <!-- Message -->
        <TextView
            android:id="@+id/prayerMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="It's time for Maghrib prayer"
            android:textSize="18sp"
            android:textColor="#B3FFFFFF"
            android:gravity="center"
            android:maxWidth="320dp" />

        <!-- Iqama label (shown after adhan audio ends) -->
        <TextView
            android:id="@+id/iqamaLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Iqama in"
            android:textSize="16sp"
            android:textColor="#80FFFFFF"
            android:gravity="center"
            android:layout_marginTop="28dp"
            android:visibility="gone" />

        <!-- Live iqama countdown -->
        <TextView
            android:id="@+id/iqamaCountdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10:00"
            android:textSize="64sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:layout_marginTop="4dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Vibration control buttons — shown only when silent/vibrate mode is active -->
    <LinearLayout
        android:id="@+id/btnContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="48dp"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:visibility="gone">

        <!-- Stop Vibrate Button -->
        <Button
            android:id="@+id/btnVibrateAlways"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Stop Vibrate"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/btn_vibrate_always"
            android:textAllCaps="false" />

        <!-- Keep Vibrate Button -->
        <Button
            android:id="@+id/btnKeepVibrate"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Keep Vibrate"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/btn_close"
            android:textAllCaps="false" />

    </LinearLayout>

</RelativeLayout>
