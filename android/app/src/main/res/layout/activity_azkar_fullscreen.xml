<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_adhan_fullscreen">

    <!-- Dismiss X button top-right -->
    <Button
        android:id="@+id/btnAzkarDismiss"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:text="✕"
        android:textSize="20sp"
        android:textColor="#CCFFFFFF"
        android:background="@drawable/bg_dismiss_circle"
        android:textAllCaps="false"
        android:elevation="4dp" />

    <!-- Header: emoji + title + prayer name -->
    <LinearLayout
        android:id="@+id/azkarHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/btnAzkarDismiss"
        android:layout_marginTop="2dp"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingBottom="6dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🤲"
            android:textSize="34sp"
            android:gravity="center" />

        <TextView
            android:id="@+id/azkarTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="أذكار بعد الصلاة"
            android:textColor="#F5B301"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:id="@+id/azkarPrayerName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text=""
            android:textColor="#80FFFFFF"
            android:textSize="13sp"
            android:gravity="center" />

    </LinearLayout>

    <!-- Progress counter -->
    <TextView
        android:id="@+id/azkarProgressText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/azkarHeader"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:text="0 / 0"
        android:textColor="#80FFFFFF"
        android:textSize="12sp"
        android:gravity="end" />

    <!-- Scrollable azkar list -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/azkarScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/azkarProgressText"
        android:layout_marginTop="6dp">

        <LinearLayout
            android:id="@+id/azkarContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="32dp" />

    </androidx.core.widget.NestedScrollView>

</RelativeLayout>
